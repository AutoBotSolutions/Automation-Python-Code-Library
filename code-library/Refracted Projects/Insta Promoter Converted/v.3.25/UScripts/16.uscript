define AutoLoadBlackWhiteList(#RunAutoLoadBlackWhiteList) {
    if($comparison(#white_list,"!= Does not equal",$nothing)) {
        then {
            set(#white_trigger,1,"Global")
        }
    }
    if($comparison(#black_list,"!= Does not equal",$nothing)) {
        then {
            set(#black_trigger,1,"Global")
        }
    }
    if($comparison(#black_list_likes,"!= Does not equal",$nothing)) {
        then {
            set(#black_like_trigger,1,"Global")
        }
    }
    if($comparison(#black_list_comments,"!= Does not equal",$nothing)) {
        then {
            set(#black_comm_trigger,1,"Global")
        }
    }
}
