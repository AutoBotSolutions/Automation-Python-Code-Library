define $DontFollowBlacklist(#RunDontFollow) {
    set(#skip_user,0,"Global")
    if($comparison(#black_list,"!=",$nothing)) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - BLACKLIST DETECTED RUNNING BLACKLIST USERNAME CHECK FOR BLACKLISTING OF USERNAME - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Bigtable.dll", "Clear large list", "user_url")
            plugin command("Bigtable.dll", "large List from Regex", "user_url", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\"username\":\")[a-z0-9_.]+(?=\",\"blocked_by_viewer)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "user_url")
            if($comparison($plugin function("Bigtable.dll", "Large list item", "user_url", 0),"!= Does not equal",$nothing)) {
                then {
                    set(#user_url,$plugin function("Bigtable.dll", "Large list item", "user_url", 0),"Global")
                    plugin command("Bigtable.dll", "Clear large list", "blacklist")
                    plugin command("Bigtable.dll", "Large list from file", "blacklist", #black_list)
                    set(#black_list_pos,0,"Global")
                    loop($plugin function("Bigtable.dll", "Large list total", "blacklist")) {
                        if($comparison($plugin function("Bigtable.dll", "Large list item", "blacklist", #black_list_pos),"= Equals",#user_url)) {
                            then {
                                set(#skip_user,1,"Global")
                            }
                        }
                        increment(#black_list_pos)
                    }
                    if($comparison(#skip_user,"= Equals",1)) {
                        then {
                            DateTimeLogStamp(#RunDateTimeLogStamp)
                            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - BLACK LISTSTED USER DETECTED [{#user_url}] SKIPING TO NEXT USER IN THE LIST - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                        }
                    }
                }
            }
        }
    }
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
}
