define FollowButtonClick(#RunFollowButtonClick) {
    plugin command("ExBrowser.dll", "ExBrowser Scroll Browser", "-10000", "-10000")
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/main/article/header/section/div[1]/span")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/article/header/section/div[1]/span")
        }
    }
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://html/body/div[4]/div/div[2]/div/article/header/div[2]/div[1]/div[2]/span[2]/button")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://html/body/div[4]/div/div[2]/div/article/header/div[2]/div[1]/div[2]/span[2]/button")
        }
    }
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/main/div/div/article/header/div[2]/div[1]/div[2]/span[2]/button")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/div/article/header/div[2]/div[1]/div[2]/span[2]/button")
        }
    }
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/main/div/header/section/div[1]/span/span[1]/button")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/div[1]/span/span[1]/button")
        }
    }
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/main/div/header/section/div[1]/span/button")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/div[1]/span/button")
        }
    }
}
