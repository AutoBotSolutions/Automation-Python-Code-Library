Cycle Mass Unfollows = [{#num_unfollow}] 
Enable Unfollows = [{#unfollow_off_on}] 
Enable Autofollows = [{#autofollow_off_on}] 
Enable Multi Tool = [{#enable_actioning}] 
Enable Comments = [{#enable_commenting}] 
Enable Likes = [{#enable_likeing}] 
Enable Following = [{#enable_following}]

DELAY SETTINGS:
Set Delay Counter (Sec.) = [{#delay_time}]
Stop The Software At = [{#succession_stop_bot_at}]
Master Delay - Seconds = [{#master_delay}]
Run When Complete = [{#run_when_complete}]
Random Wait .1 = [{#random_wait_one}]
Random Wait .2 = [{#random_wait_two}]
Wait After Action Delay = [{#wait_after}]

ADVANCED SETTINGS:
Likes Per User - Min = [{#likes_per_user1}]
Likes Per User - Max = [{#likes_per_user2}]
Comment Per User - Min = [{#comments_per_user1}]
Comment Per User - Max = [{#comments_per_user2}]
Select Multi Tool Action = [{#MultiToolAction}]
Randomize Succession = [{#RandomizeSuccession}]
End Succession Comment = [{#DisableCommenting}]
End Succession Liking = [{#DisableLikeing}]
End Succession Following = [{#DisableFollowing}]
End Succession Unfollow = [{#DisableUnfollow}]
EndSuccessionFollowBack = [{#DisableFollowBack}]
EndSuccessionMultiTool = [{#DisableMutilTool}]
Stop Succession Module = [{#succession_stop_bot_at}]
Stop Bot On End Criteria = [{#StopBotOnEndCriteria}]
Save Log To File = [{#SaveLogToFile}]

ACCOUNT ROTATION:
Enable Account Rotation = [{#EnableAccountRotation}]
Rotate Account At Total = [{#rotate_account_at}]
Rotate On End Criteria = [{#RotateOnEndCriteria}]

SUPERUSER SETTINGS:
Popular Posts = [{#top_posts}]
Skip Likes/Comments = [{#advanced_skip}]
Randomize Scrape List = [{#RandomizeScrapeList}]
Follow IF Ratio (>) Then = [{#FollowGreaterThen}]
Follow IF Ratio (<) Then = [{#FollowLessThen}]
Follow IF Ratio (=) To = [{#FollowEqualTo}]
Skip - If Tagged With = [{#SkipIfTaggedWithThis}]
Skip - Likes/Comments = [{#advanced_skip}]
Skip - Link In Bio = [{#SkipBioLinkAccounts}]
Skip - Account is Private = [{#SkipPrivateAccount}]
Skip - No posts yet = [{#SkipNopostsyet}]
Skip - non-English = [{#SkipnonEnglishSpeaking}]

REQUIRED FILES:
Account File Path = [{#account_file}]
Proxy File Path = [{#proxy_file}]
Keyword File Path = [{#keyword_file}]
Comment File Path = [{#comment_file}]

BLACK & WHITE LISTS:
White List Unfollow File = [{#white_list}]
Black List Follow File = [{#black_list}]
Black List Likes File = [{#black_list_likes}]
Black List Comments File = [{#black_list_comments}]", "False", "True", "False", "True", "True,False,False", "300,350", "False", 000000, "FF0000,000000", "FFF3C1C1,000000", "FF778ABD,000000", "Center App"),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
}
