define QuickView1(#RunQuickView1) {
    comment("Sucession Module Quick Acsess Settings")
    set(#SuccessionSettingsConfig,$plugin function("Advanced Dialog.dll", "$text box dialog", "SUCSESSTION MODULE SETTINGS CONFIG", "USER INTERFACE SETTINGS:
Cycle Follows Per Tag = [{#follow_per_tag}] 
Cycle Likes Per Tag = [{#like_per_tag}] 
Cycle Comments Per Tag = [{#comment_per_tag}] 
Cycle Actions Per Tag = [{#action_per_tag}] 
