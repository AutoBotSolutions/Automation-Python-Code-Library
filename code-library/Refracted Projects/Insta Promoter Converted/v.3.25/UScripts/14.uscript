    increment(#PasswordRow)
    increment(#ProxyRow)
    increment(#FollowRow)
    increment(#LikesRow)
    increment(#CommentsRow)
    increment(#ActionRow)
    increment(#FollowBackRow)
    increment(#UnfollowRow)
