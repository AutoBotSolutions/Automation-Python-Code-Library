define $SuccessionLoopSetupSscript(#RunSuccessionLoopSetupSscript) {
    set(#diplay_running,"","Global")
    set(#count_ui_display,0,"Global")
    set(#delay_ticker,0,"Global")
    set(#delay_ticker,#delay_time,"Global")
    set(#follow_queue,0,"Global")
    set(#like_queue,0,"Global")
    set(#comment_queue,0,"Global")
    set(#autofollow_queue,0,"Global")
    set(#action_queue,0,"Global")
    set(#unfollow_queue,0,"Global")
    set(#FollowColor,"#d9d9d9","Global")
    set(#LikeColor,"#d9d9d9","Global")
    set(#CommentColor,"#d9d9d9","Global")
    set(#ActionsColor,"#d9d9d9","Global")
    set(#AutoFollowColor,"#d9d9d9","Global")
    set(#UnfollowColor,"#d9d9d9","Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SUCCESSION LOOP SETUP - QUEUE AND DELAY TIMERS REST - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define $SuccessionSetupSscript(#RunSuccessionSetupSscript) {
    plugin command("Bigtable.dll", "Clear all large list")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - CLEARING AND RESETING LISTS AND COUNTERS - SUCCESSION BOT - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    if($comparison(#keyword_file,"!= Does not equal","")) {
        then {
            plugin command("Bigtable.dll", "Large list from file", "keywords", #keyword_file)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - KEYWORD LIST WAS LOADED AND CREATED SUCCESSFULLY! - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
        else {
            if($comparison(#RunFromProjectFolder,"!= Does not equal","YES")) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TO USE THE SOFTWARE PLEASE ADD YOUR KEYWORD FILE TO THE SOFTWARE INTERFACE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
    if($comparison(#comment_file,"!= Does not equal",$nothing)) {
        then {
            plugin command("Bigtable.dll", "Large list from file", "comments", #comment_file)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - COMMENT LIST WAS LOADED AND CREATED SUCCESSFULLY! - COMMENT BOT - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
        else {
            if($comparison(#RunFromProjectFolder,"!= Does not equal","YES")) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TO USE THE COMMENT BOT PLEASE ADD YOUR KEYWORD FILE TO THE SOFTWARE INTERFACE - COMMENT BOT - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
    set(#RunSuccessionValueSets,$SuccessionValueSets(#RunSuccessionValueSets),"Global")
    if($comparison(#RunFromProjectFolder,"= Equals","YES")) {
        then {
            BuildProjectFilePaths(#BuildProjectFilePaths)
        }
    }
}
define $SuccessionValueSets(#RunSuccessionValueSets) {
    comment("RUNS AT THE BOTTOM OF SUCSESSTION SETUP SCRIPT")
    if($comparison(#likes_per_user1,"= Equals","")) {
        then {
            set(#likes_per_user1,1,"Global")
        }
    }
    if($comparison(#likes_per_user2,"= Equals","")) {
        then {
            set(#likes_per_user2,1,"Global")
        }
    }
    if($comparison(#comments_per_user1,"= Equals","")) {
        then {
            set(#comments_per_user1,1,"Global")
        }
    }
    if($comparison(#comments_per_user2,"= Equals","")) {
        then {
            set(#comments_per_user2,1,"Global")
        }
    }
    if($comparison(#rotate_account_at,"= Equals",$nothing)) {
        then {
            set(#rotate_account_at,"X","Global")
        }
    }
    if($comparison(#MultiToolAction,"= Equals","")) {
        then {
            set(#MultiToolAction,"Follow - Like","Global")
        }
    }
    if($comparison(#DisableCommenting,"= Equals","")) {
        then {
            set(#DisableCommenting,"X","Global")
        }
    }
    if($comparison(#DisableLikeing,"= Equals","")) {
        then {
            set(#DisableLikeing,"X","Global")
        }
    }
    if($comparison(#DisableFollowing,"= Equals","")) {
        then {
            set(#DisableFollowing,"X","Global")
        }
    }
    if($comparison(#succession_stop_bot_at,"= Equals","")) {
        then {
            set(#succession_stop_bot_at,"X","Global")
        }
    }
    if($comparison(#DisableUnfollow,"= Equals","")) {
        then {
            set(#DisableUnfollow,"X","Global")
        }
    }
    if($comparison(#FollowGreaterThen,"= Equals","")) {
        then {
            set(#FollowGreaterThen,"X","Global")
        }
    }
    if($comparison(#FollowLessThen,"= Equals","")) {
        then {
            set(#FollowLessThen,"X","Global")
        }
    }
    if($comparison(#FollowEqualTo,"= Equals","")) {
        then {
            set(#FollowEqualTo,"X","Global")
        }
    }
    if($comparison(#DisableFollowBack,"= Equals","")) {
        then {
            set(#DisableFollowBack,"Not Recommended","Global")
        }
    }
    if($comparison(#DisableMutilTool,"= Equals","")) {
        then {
            set(#DisableMutilTool,"Not Recommended","Global")
        }
    }
    set(#diplay_running,"","Global")
    set(#count_ui_display,0,"Global")
    set(#delay_ticker,0,"Global")
    set(#delay_ticker,#delay_time,"Global")
    set(#keyword_file_pos,0,"Global")
    set(#comment_file_pos,0,"Global")
    set(#follow_queue,0,"Global")
    set(#follow_counter,0,"Global")
    set(#autofollow_counter,0,"Global")
    set(#autofollow_queue,0,"Global")
    set(#action_queue,0,"Global")
    set(#action_counter,0,"Global")
    set(#like_queue,0,"Global")
    set(#like_counter,0,"Global")
    set(#comment_queue,0,"Global")
    set(#comment_counter,0,"Global")
    set(#unfollow_counter,0,"Global")
    set(#unfollow_queue,0,"Global")
    set(#FollowColor,"#d9d9d9","Global")
    set(#LikeColor,"#d9d9d9","Global")
    set(#CommentColor,"#d9d9d9","Global")
    set(#ActionsColor,"#d9d9d9","Global")
    set(#AutoFollowColor,"#d9d9d9","Global")
    set(#UnfollowColor,"#d9d9d9","Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SUCCESSION SETUP, QUEUE, COUNTERS AND LIST POSITIONS REST -  - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define SettingsConfigErrorThrough(#RunSettingsConfigErrorThrough) {
    if($both($comparison(#RotateOnEndCriteria,"= Equals","YES"),$comparison(#StopBotOnEndCriteria,"= Equals","NO"))) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED - YOU CAN'T HAVE Rotate On End Criteria = YES AND Stop Bot On End Criteria = NO - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED - PLEASE CHANGE Stop Bot On End Criteria TO = YES - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            wait(1)
            plugin command("Advanced Systems.dll", "system sound play", "Hand")
            pause script
        }
    }
    if($both($comparison(#EnableAccountRotation,"= Equals","NO"),$comparison(#RotateOnEndCriteria,"= Equals","YES"))) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED - YOU CAN'T HAVE Enable Account Rotation = NO & Rotate On End Criteria = YES - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED - PLEASE CHANGE Enable Account Rotation TO = YES - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            wait(1)
            plugin command("Advanced Systems.dll", "system sound play", "Hand")
            pause script
        }
    }
    if($both($comparison(#rotate_account_at,"!= Does not equal","X"),$comparison(#RotateOnEndCriteria,"= Equals","YES"))) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED - YOU CAN'T HAVE Rotate Account At Total ENABELED AND Rotate On End Criteria ENABELED TOGETHER, PLEASE CHOSE ONE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            wait(1)
            plugin command("Advanced Systems.dll", "system sound play", "Hand")
            pause script
        }
    }
}
