ui button("Open &nbsp;Settings") {
    set(#null,$plugin function("Advanced Dialog.dll", "$dropdown dialog", "Quick Settings View", "", "CLIENT PORTAL,-------------------------------,[ Post Module ],[ Scrape Module ],[ Succession Module ],-------------------------------,Required Files,Delay Settings,White - Black List,Ratio Calculator,Advanced Settings,Save/Load Settings,Project Settings,Superuser Settings,Open Account Stats,Project Folders,Settings Quick View", 280, 125, "False", 000000, "FFBEEAC4,FDFEFE", "FFF3C1C1,FDFEFE", "Center App", "True", "{$special folder("Application")}\\img\\inp.ico"),"Global")
    if($comparison(#null,"= Equals","Delay Settings")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Delay Settings")
        }
    }
    if($comparison(#null,"= Equals","White - Black List")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "List Settings")
        }
    }
    if($comparison(#null,"= Equals","Ratio Calculator")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Ratio Calculator")
        }
    }
    if($comparison(#null,"= Equals","Advanced Settings")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Advanced Settings")
        }
    }
    if($comparison(#null,"= Equals","Required Files")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Required Files")
        }
    }
    if($comparison(#null,"= Equals","Save/Load Settings")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SAVE & LOAD SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Ubot.dll", "menu item click", "Save/Load Settings")
        }
    }
    if($comparison(#null,"= Equals","Settings Quick View")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - QUICK SETTINGS VIEW OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            QuickView4(#RunQuickView4)
        }
    }
    if($comparison(#null,"= Equals","Superuser Settings")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SUPERUSER SETTINGS VIEW OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            if($file exists("{$special folder("Application")}\\temp\\3.txt")) {
                then {
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "These settings are for professional social media marketers, please don\'t enable these settings if your unsure how to use them. They will impact the performance of the software, and the result you incur with the software, You have been warned!", "Professional Marketers Only!", "I Understand", "Warning", "ServiceNotification", "Button 1"),"Global")
                    delete file("{$special folder("Application")}\\temp\\3.txt")
                }
            }
            plugin command("Advanced Ubot.dll", "menu item click", "Superuser Settings")
        }
    }
    if($comparison(#null,"= Equals","CLIENT PORTAL")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PROJECT FOLDER SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            ClientFeedback(#RunClientFeedback)
        }
    }
    if($comparison(#null,"= Equals","Project Settings")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PROJECT FOLDER SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Ubot.dll", "menu item click", "Project Settings")
        }
    }
    if($comparison(#null,"= Equals","Project Folders")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PROJECT FOLDER SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            OpenProjectFolder(#OpenProjectFolder)
        }
    }
    if($comparison(#null,"= Equals","Open Account Stats")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - OPEN ACCOUNT STATS SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            Open Account Stats(#RunOpenAccountStats)
        }
    }
    if($comparison(#null,"= Equals","[ Post Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Post Module ]", 0, "True")
        }
    }
    if($comparison(#null,"= Equals","[ Succession Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Succession Module ]", 0, "False")
        }
    }
    if($comparison(#null,"= Equals","[ Scrape Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Scrape Module ]", 0, "False")
        }
    }
}
ui button("Rest &nbsp;Software&nbsp;") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to close the browser and rest the accounts list?", "ALERT!", "Yes/No/Cancel", "Question", "Default Desktop Only", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes")) {
        then {
            StartLogRunning(#OpenLog)
            InstaPromoterDriverKiller(#RunInstaPromoterDriverKiller)
            Account Rest(#Rest Accounts)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - STOP BUTTON ENGAGED SOFTWARE STOPPED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            TargetRestSoftwareButton(#RunRestTargetRestSoftwareButton)
            plugin command("Advanced Ubot.dll", "main button click", "Stop")
            stop script
        }
    }
}
ui stat monitor("Master Countdown",#count_ui_display)
ui button("Start &nbsp;Software") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to start the software?", "ALERT!", "Yes/No/Cancel", "Question", "Default Desktop Only", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - THE START BUTTON HAS BEEN ENGAGED BOTTING OPERATION NOW STARTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            set(#TargetModuleActive,1,"Global")
            plugin command("Advanced Ubot.dll", "main button click", "Run")
        }
    }
}
ui button("Account - Login") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to login? If you already logged in to the browser this action will close the current browser and launch a new one and login into the next account in the list.", "ALERT!", "Yes Login/Cancel", "Question", "None", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes Login")) {
        then {
            StartLogRunning(#OpenLog)
            InstaPromoterDriverKiller(#RunInstaPromoterDriverKiller)
            set(#RunRotationLogin,$RotationLoginFunction(#RunRotationLogin),"Global")
            if($comparison($table total columns(&statistics),"< Less than",10)) {
                then {
                    TargetCreateStatsTable(#RunTargetCreateStatsTable)
                }
            }
        }
    }
}
