    ui text box("Custom SaveLoad Path",#custom_settings_path)
    ui button("Select Custom SaveLoad Folder") {
        set(#custom_settings_path,$plugin function("Advanced Dialog.dll", "$folder browser dialog", "Please select a folder.", "", "", "False"),"Global")
    }
    ui button("Save Settings") {
        set(#RunSaveCustomFolder,$SaveCustomFolder(#RunSaveCustomFolder),"Global")
    }
    ui button("Load Settings") {
        set(#RunLoadCustomFolder,$LoadCustomFolder(#RunLoadCustomFolder),"Global")
    }
    ui stat monitor(#main ui,"")
}
ui window("Superuser Settings") {
    ui text box("Set User Agent String",#user_agent)
    ui drop down("Popular Posts",",KEEP,REMOVE",#top_posts)
    ui drop down("Randomize Target List",",YES,NO",#RandomizeScrapeList)
    ui stat monitor(#main ui,"")
    ui stat monitor("<font color=\"#ffff00\">Followers To Following</font>","")
    ui text box("Follow Ratio Is Grater",#FollowGreaterThen)
    ui stat monitor("<font color=\"#ffff00\">Is Greater Than</font>","")
    ui text box("Follow Ratio Is Less",#FollowLessThen)
    ui stat monitor("<font color=\"#ffff00\">Is Less Than</font>","")
    ui text box("Follow Ratio Is Equal",#FollowEqualTo)
    ui stat monitor("<font color=\"#ffff00\">Is Equal To</font>","")
    ui text box("Skip - If Tagged With",#SkipIfTaggedWithThis)
    ui stat monitor("<font color=\"#ffff00\">(Comma Separate Tags)</font>","")
    ui stat monitor("<br />","")
    ui drop down("Skip - Likes/Comments",",(Seconds) Skip If Not Contains,(Minutes) Skip If Not Contains,(Current Month) Skip If Not Contains",#advanced_skip)
    ui drop down("Skip - Link In Bio",",YES,NO",#SkipBioLinkAccounts)
    ui drop down("Skip - Account is Private",",YES,NO",#SkipPrivateAccount)
    ui drop down("Skip - No posts yet",",YES,NO",#SkipNopostsyet)
    ui drop down("Skip - non-English",",YES,NO",#SkipnonEnglishSpeaking)
    ui stat monitor("<font color=\"#ffff00\">Advanced Skip Options</font>","")
}
ui window("Project Settings") {
    ui drop down("Run From Project Folder",",YES,NO",#RunFromProjectFolder)
    ui stat monitor("<font color=\"#ffff00\">Save Project Settings</font>","")
    ui text box("Project Target Folder",#custom_settings_path)
    ui button("Select The Target Project Folder") {
        if($comparison(#ipdf_path,"= Equals",$nothing)) {
            then {
                set(#custom_settings_path,$plugin function("Advanced Dialog.dll", "$folder browser dialog", "Please select a folder.", $special folder("Application"), "{$special folder("Application")}\\projects\\", "True"),"Global")
            }
            else {
                set(#custom_settings_path,$plugin function("Advanced Dialog.dll", "$folder browser dialog", "Please select a folder.", $special folder("My Documents"), "{$special folder("My Documents")}\\Insta Promoter Data Folder\\projects\\", "True"),"Global")
            }
        }
        stop script
    }
    ui button("Save Settings To Target Project") {
        set(#ProjectSaveTargetModule,$ProjectSaveTargetModule("ProjectSaveTargetModule"),"Global")
    }
    ui stat monitor("<br />","")
    ui button("Open - Project Folder Directory") {
        if($comparison(#ipdf_path,"!= Does not equal",$nothing)) {
            then {
                plugin command("Advanced Data Text File.dll", "open file/url", "{$special folder("My Documents")}\\Insta Promoter Data Folder\\projects")
            }
            else {
                plugin command("Advanced Data Text File.dll", "open file/url", "{$special folder("Application")}\\projects")
            }
        }
    }
    ui stat monitor("<br>","")
    ui text box("Data File Path",#ipdf_path)
    ui button("Build Insta Promoter Data Folder") {
        set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "VERY IMPORTANT! if you use this option to \"Build Insta Promoter Data Folder\" you must setup and use this directory \"C:\\Users\\%username%\\Documents\\Insta Promoter Data Folder\" and the software will run from this directory until the \"Insta Promoter Data Folder\" is removed. It\'s highly recommended to use this option and not the installation folders to run from, as the install folders may get replaced during updates, and this directory will only get replaced if you \"Build Insta Promoter Data Folder\" again.", "ALERT!", "Ok Complete Build/Cancel Request", "Question", "None", "Button 1"),"Global")
        if($comparison(#null,"= Equals","Ok Complete Build")) {
            then {
                shell("{$special folder("Application")}\\inst\\ipdf-setup.exe")
                set(#ipdf_path,"{$special folder("My Documents")}\\Insta Promoter Data Folder","Global")
            }
            else {
                alert("Request Canceled")
            }
        }
    }
    ui stat monitor(#main ui,"")
}
