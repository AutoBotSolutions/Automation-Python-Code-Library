        set(#stop_bot_at,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Stop The Software At"),"Global")
        set(#master_delay,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Master Delay - Seconds"),"Global")
        set(#run_when_complete,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Run When Complete"),"Global")
        set(#random_wait_one,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Random Wait .1"),"Global")
        set(#random_wait_two,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Random Wait .2"),"Global")
        set(#account_file,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Account File Path"),"Global")
        set(#proxy_file,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Proxy File Path"),"Global")
        set(#image_captions,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Image Caption File Path"),"Global")
        set(#TargetUsername,$plugin function("IniFileReader.dll", "$ini read", "Scrape Module", "Enter Target Username"),"Global")
