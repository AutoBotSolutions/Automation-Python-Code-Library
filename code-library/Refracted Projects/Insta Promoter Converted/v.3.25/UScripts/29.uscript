        run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ALL MODULE SETTINGS SAVED: CUSTOM PATH [{#custom_settings_path}\\Settings Config.ini] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    }
}
define $LoadCustomFolder(#RunLoadCustomFolder) {
    StartLogRunning(#OpenLog)
    plugin command("IniFileReader.dll", "ini container", "{#custom_settings_path}\\Settings Config.ini") {
        set(#post_options,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Choose Post Option"),"Global")
        set(#num_post_now,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Number To Post Now"),"Global")
        set(#current_date_time,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Date Time Sec Designator"),"Global")
        set(#next_post_in,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Next Post Date Time"),"Global")
        set(#post_schedule,$plugin function("IniFileReader.dll", "$ini read", "Post Module", "Enter Your Post Schedule"),"Global")
