define $SaveCustomFolder(#RunSaveCustomFolder) {
    StartLogRunning(#OpenLog)
    if($file exists("{#custom_settings_path}\\Settings Config.ini")) {
        then {
            delete file("{#custom_settings_path}\\Settings Config.ini")
        }
    }
    plugin command("IniFileReader.dll", "ini container", "{#custom_settings_path}\\Settings Config.ini") {
        plugin command("IniFileReader.dll", "ini write", "Post Module", "Choose Post Option", #post_options)
        plugin command("IniFileReader.dll", "ini write", "Post Module", "Number To Post Now", #num_post_now)
        plugin command("IniFileReader.dll", "ini write", "Post Module", "Date Time Sec Designator", #current_date_time)
