define SuccessionAppStarted(#RunSuccessionAppStarted) {
    comment("Place in Start button to 
trigger a goal in your 
statistics dashboard. 
( App Started )")
    set(#anti_cache,$rand(123,1234),"Global")
    set(#AppStartClick,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&idgoal=2", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "http://app.tracking.softwareautomation.org", "", 20),"Global")
    set(#AppStartClick,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=Succession Module Started&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
}
