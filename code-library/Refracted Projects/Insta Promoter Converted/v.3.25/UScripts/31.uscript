    set(#ApplicationOpened,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?_cvar=\{\"1\":[\"Ubot\",\"Insta Promoter 3.15\"],\"2\":[\"Matomo HTTP API Tracking\",\"1\"],\"3\":[\"Locale\",\"en::en\"]\}&idsite=1&rec=1&_id=\{#session_id\}&rand=\{#anti_cache\}&apiv=1&action_name=Insta Promoter - Reversion Build 3.18 - Portable Build 66.0.3359.139&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
    set(#ApplicationOpened,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=Insta Promoter - Reversion Build 3.18 - Portable Build 66.0.3359.139&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
}
