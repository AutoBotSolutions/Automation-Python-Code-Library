define InstaPromoterDriverKiller(#RunInstaPromoterDriverKiller) {
    set(#instapromoterPID,$plugin function("Advanced Systems.dll", "$system get process id", "insta-promoter", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "instapromoterPID", #instapromoterPID, $new line, "replace")
    set(#instapromoterPIDtotal,$plugin function("Bigtable.dll", "Large list total", "instapromoterPID"),"Global")
    if($comparison(#instapromoterPID,"!= Does not equal",$nothing)) {
        then {
            loop(#instapromoterPIDtotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "instapromoterPID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "instapromoterPID", 0)
            }
        }
    }
    set(#ChromeDriverPID,$plugin function("Advanced Systems.dll", "$system get process id", "chromedriver238x", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "ChromeDriverPID", #ChromeDriverPID, $new line, "replace")
    set(#ChromeDriverPIDTotal,$plugin function("Bigtable.dll", "Large list total", "ChromeDriverPID"),"Global")
    if($comparison(#ChromeDriverPID,"!= Does not equal","")) {
        then {
            loop(#ChromeDriverPIDTotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "ChromeDriverPID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "ChromeDriverPID", 0)
            }
        }
    }
}
define ChromeDriverKiller(#ChromeKillerCode) {
    set(#instapromoterPID,$plugin function("Advanced Systems.dll", "$system get process id", "insta-promoter", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "instapromoterPID", #instapromoterPID, $new line, "replace")
    set(#instapromoterPIDtotal,$plugin function("Bigtable.dll", "Large list total", "instapromoterPID"),"Global")
    set(#chromePID,$plugin function("Advanced Systems.dll", "$system get process id", "chrome", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "chromePID", #chromePID, $new line, "replace")
    set(#chromePIDtotal,$plugin function("Bigtable.dll", "Large list total", "chromePID"),"Global")
    set(#ChromeDriverPID,$plugin function("Advanced Systems.dll", "$system get process id", "chromedriver238x", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "ChromeDriverPID", #ChromeDriverPID, $new line, "replace")
    set(#ChromeDriverPIDTotal,$plugin function("Bigtable.dll", "Large list total", "ChromeDriverPID"),"Global")
    set(#ChromePID,$plugin function("Advanced Systems.dll", "$system get process id", "Chrome", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "ChromePID", #ChromePID, $new line, "replace")
    set(#ChromePIDTotal,$plugin function("Bigtable.dll", "Large list total", "ChromePID"),"Global")
    set(#GoogleChromePID,$plugin function("Advanced Systems.dll", "$system get process id", "Google Chrome", "False", "False", "True"),"Global")
    plugin command("Bigtable.dll", "large List from text", "GoogleChromePID", #GoogleChromePID, $new line, "replace")
    set(#GoogleChromePIDTotal,$plugin function("Bigtable.dll", "Large list total", "GoogleChromePID"),"Global")
    if($comparison(#instapromoterPID,"!= Does not equal",$nothing)) {
        then {
            loop(#instapromoterPIDtotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "instapromoterPID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "instapromoterPID", 0)
            }
        }
    }
    if($comparison(#chromePID,"!= Does not equal",$nothing)) {
        then {
            loop(#chromePIDtotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "chromePID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "chromePID", 0)
            }
        }
    }
    if($comparison(#GoogleChromePID,"!= Does not equal",$nothing)) {
        then {
            loop(#GoogleChromePIDTotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "GoogleChromePID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "GoogleChromePID", 0)
            }
        }
    }
    if($comparison(#ChromePID,"!= Does not equal",$nothing)) {
        then {
            loop(#ChromePIDTotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "ChromePID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "ChromePID", 0)
            }
        }
    }
    if($comparison(#ChromeDriverPID,"!= Does not equal","")) {
        then {
            loop(#ChromeDriverPIDTotal) {
                plugin command("Communication.dll", "kill process", $plugin function("Bigtable.dll", "Large list item", "ChromeDriverPID", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "ChromeDriverPID", 0)
            }
        }
    }
    plugin command("ExBrowser.dll", "ExBrowser CleanUp", "Yes")
}
define StartLogRunning(#OpenLog) {
    if($not($exists(<id="textarea_id">))) {
        then {
            set(#browser ui,$read file("{$special folder("Application")}\\htui\\log-ui.html"),"Global")
            load html(#browser ui)
            wait(3)
            wait for element(<id="textarea_id">,10,"Appear")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ADVANCED LOG LOADED SUCSESSFULLY - WATCH FOR ACTIVITY AND ERRORS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
}
