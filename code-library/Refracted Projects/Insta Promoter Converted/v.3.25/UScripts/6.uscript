define RatioCalculator(#ClaculateRatio) {
    set(#Ratio,$divide(#Followers,#Following),"Global")
    set(#div,$divide(#Followers,#Following),"Global")
    set(#Ratio,$eval("Math.round( {#Ratio} * 10 ) / 10;"),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - RATIO - FOLLOWERS = {#Followers} FOLLOWING = {#Following} , {#Followers} ÷ {#Following} (x) = [{#Ratio}] , YOUR ACCOUNT RATIO = ({#Ratio}) - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define $ClearLogSystem(#LogClearCommand) {
    if($exists(<id="textarea_id">)) {
        then {
            plugin command("Bigtable.dll", "Clear large list", "log_scrape")
            set(#log_scrape,$scrape attribute(<id="textarea_id">,"value"),"Global")
            plugin command("Bigtable.dll", "large List from text", "log_scrape", #log_scrape, $new line, "replace")
        }
    }
    if($comparison($plugin function("Bigtable.dll", "Large list total", "log_scrape"),">= Greater than or equal to",300)) {
        then {
            if($comparison(#SaveLogToFile,"= Equals","YES")) {
                then {
                    set(#RunRemoveLog,$RemoveLog(#RunRemoveLog),"Global")
                    set(#append_log_num,$plugin function("Advanced Data Text File.dll", "$random", 1000, 9000, "Int", ""),"Global")
                    create folder($special folder("Application"),"log")
                    set(#datetimelog,$plugin function("DateTime Manipulation.dll", "$datetime manipulation", $date, "UBOT", "UNIX", "en-US", "en-US"),"Global")
                    save to file("{$special folder("Application")}\\log\\{#datetimelog} [{#append_log_num}].txt",$plugin function("Bigtable.dll", "Large list return", "log_scrape"))
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ADVANCED LOG OUTPUT SAVED [Insta Promoter\\log\\{#datetimelog} [{#append_log_num}].txt] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
            if($exists(<id="textarea_id">)) {
                then {
                    change attribute(<id="textarea_id">,"value","")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ADVANCED LOG CLEARED SUCSESSFULLY - NEW ACTIVITY AND ERRORS LOG STARTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
            plugin command("Bigtable.dll", "Clear large list", "log_scrape")
            set(#log_scrape,$nothing,"Global")
        }
    }
}
define $master_delay_timers(#run_master_delay) {
    if($comparison(#master_delay_trigger,"!=",#run_when_complete)) {
        then {
            if($both($comparison(#random_wait_one,"!=",$nothing),$comparison(#random_wait_two,"!=",$nothing))) {
                then {
                    if($both($comparison(#random_wait_one,"!=",0),$comparison(#random_wait_two,"!=",0))) {
                        then {
                            set(#diplay_running,"<font color=\"#FF0000\"><strong>Random Delay Running!</stong></font>","Global")
                            set(#random_wait,$rand(#random_wait_one,#random_wait_two),"Global")
                            set(#count_ui_display,#random_wait,"Global")
                            set(#Random Loop,#random_wait,"Local")
                            DateTimeLogStamp(#RunDateTimeLogStamp)
                            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - RANDOM WAIT HAS STARTED - RANDOM WAIT WAITING FOR [{#random_wait}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                            loop(#Random Loop) {
                                wait(1)
                                decrement(#count_ui_display)
                            }
                            set(#count_ui_display,0,"Global")
                            DateTimeLogStamp(#RunDateTimeLogStamp)
                            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - RANDOM WAIT HAS COMPLETED - BOTTING CONTINUING IN [{#count_ui_display}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                            set(#diplay_running,$nothing,"Global")
                            set(#Random Loop,$nothing,"Local")
                        }
                    }
                }
            }
        }
        else if($both($comparison(#master_delay,"!=",""),$comparison(#run_when_complete,"!=",""))) {
            if($comparison(#master_delay_trigger,">=",#run_when_complete)) {
                then {
                    set(#diplay_running,"<font color=\"#ffff00\"><strong>Master Delay Running!</stong></font>","Global")
                    set(#master_delay_trigger,0,"Global")
                    set(#count_ui_display,#master_delay,"Global")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - MASTER DELAY HAS STARTED - DELAYING FOR [{#master_delay}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    loop(#master_delay) {
                        wait(0.9)
                        decrement(#count_ui_display)
                    }
                    set(#count_ui_display,0,"Global")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - MASTER DELAY HAS COMPLETED - BOTTING CONTINUING IN [{#count_ui_display}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    set(#diplay_running,"","Global")
                }
            }
        }
    }
    if($comparison(#delay_time,"> Greater than",0)) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - THE FLAT DELAY TIME HAS BEEN INITIATED AND IS RUNNING [{#delay_time}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            set(#diplay_running,"<font color=\"#2353ff\"><strong>Flat Wait Delay Running!</stong></font>","Global")
            set(#delay_ticker,#delay_time,"Global")
            loop(#delay_time) {
                wait(1)
                decrement(#delay_ticker)
                set(#count_ui_display,#delay_ticker,"Global")
            }
            set(#diplay_running,"","Global")
            set(#count_ui_display,0,"Global")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - THE FLAT DELAY TIME HAS COMPLETED  - SOFTWARE COMMENCING IN [{#delay_ticker}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
}
define $delay_after_action(#run_delay_after) {
    if($comparison(#wait_after,"!= Does not equal","")) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - DELAY AFTER ACTION -  DELAY TIME HAS BEEN INITIATED AND IS RUNNING [{#wait_after}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            set(#diplay_running,"<font color=\"#ee00ff\"><strong>Delay After Running!</stong></font>","Global")
            set(#delay_ticker,#wait_after,"Global")
            loop(#wait_after) {
                wait(1)
                decrement(#delay_ticker)
                set(#count_ui_display,#delay_ticker,"Global")
            }
            set(#diplay_running,"","Global")
            set(#count_ui_display,0,"Global")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - THE FLAT DELAY TIME HAS COMPLETED  - SOFTWARE COMMENCING IN [{#delay_ticker}] SECONDS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
}
define DateTimeLogStamp(#RunDateTimeLogStamp) {
    set(#time,$plugin function("DateTime Manipulation.dll", "$datetime manipulation", $date, "UBOT", "General date/time (short time)", "en-US", "en-US"),"Global")
}
define $RemoveLog(#RunRemoveLog) {
    plugin command("Bigtable.dll", "Clear large list", "get_log_paths")
    set(#log_paths,$get files("{$special folder("Application")}\\log\\","Yes"),"Global")
    plugin command("Bigtable.dll", "large List from text", "get_log_paths", #log_paths, $new line, "replace")
    if($comparison($plugin function("Bigtable.dll", "Large list total", "get_log_paths"),">= Greater than or equal to",100)) {
        then {
            loop($plugin function("Bigtable.dll", "Large list total", "get_log_paths")) {
                delete file($plugin function("Bigtable.dll", "Large list item", "get_log_paths", 0))
                plugin command("Bigtable.dll", "Large list Remove item", "get_log_paths", 0)
            }
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ADVANCED LOG OUTPUT EXCEEDS MAXIMUM NUMBER OF ENTRIES: LOGS DELETED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
    plugin command("Bigtable.dll", "Clear large list", "get_log_paths")
    set(#log_paths,$nothing,"Global")
}
