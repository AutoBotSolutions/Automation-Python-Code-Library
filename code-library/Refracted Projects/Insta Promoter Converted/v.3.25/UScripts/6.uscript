}
define ChangeLog {
    if($file exists("{$special folder("Application")}\\temp\\2.txt")) {
        then {
            set(#change_log,$read file("{$special folder("Application")}\\docs\\ChangeLog.txt"),"Global")
            in new browser {
                thread {
                    set(#change_log,$plugin function("Advanced Dialog.dll", "$text box dialog", "Insta Promoter - Portable - Change Log", #change_log, "False", "True", "False", "True", "True,False,False", "625,500", "False", 000000, "FF0000,000000", "FFF3C1C1,000000", "FF778ABD,000000", "Center App"),"Global")
                }
            }
            delete file("{$special folder("Application")}\\temp\\2.txt")
        }
    }
    LoadDataFolderPath(#RunLoadDataFolderPath)
}
define OpenProjectFolder(#OpenProjectFolder) {
    LoadDataFolderPath(#RunLoadDataFolderPath)
    if($comparison(#ipdf_path,"!= Does not equal",$nothing)) {
        then {
            plugin command("Advanced Data Text File.dll", "open file/url", "{$special folder("My Documents")}\\Insta Promoter Data Folder\\projects")
        }
        else {
            plugin command("Advanced Data Text File.dll", "open file/url", "{$special folder("Application")}\\projects")
        }
    }
}
Open List Spinner()
define BasicCommentSpinner {
    set(#SpinnerTrigger,0,"Global")
    loop while($comparison(#SpinnerTrigger,"= Equals",0)) {
        clear list(%spin_comments)
        set(#CommentSpinner,$nothing,"Global")
        set(#SpinComments,$nothing,"Global")
        set(#CommentSpinner,$plugin function("Advanced Dialog.dll", "$text box dialog", "List Spinner - Create Spintax From Lists", #CommentSpinner, "False", "True", "False", "True", "True,False,False", "600,400", "False", 000000, "FF0000,000000", "FFF3C1C1,000000", "FF778ABD,000000", "Center App"),"Global")
        add list to list(%spin_comments,$list from text(#CommentSpinner,$new line),"Delete","Global")
        set(#CommentSpinner,$plugin function("Advanced Data Text File.dll", "$list to spin syntax", %spin_comments, "\{", "\}", "|"),"Global")
        clear list(%spin_comments)
        add list to list(%spin_comments,$list from text(#CommentSpinner,$new line),"Delete","Global")
        set(#CommentSpinner,$plugin function("Advanced Dialog.dll", "$text box dialog", "List Spinner - Create Spintax From Lists", #CommentSpinner, "False", "True", "False", "True", "True,False,False", "600,400", "False", 000000, "FF0000,000000", "FFF3C1C1,000000", "FF778ABD,000000", "Center App"),"Global")
        if($comparison(#CommentSpinner,"= Equals","")) {
            then {
                set(#SpinnerTrigger,1,"Global")
            }
        }
        if($comparison(#CommentSpinner,"= Equals","\{\}")) {
            then {
                set(#SpinnerTrigger,1,"Global")
            }
        }
        clear list(%spin_comments)
        set(#CommentSpinner,$nothing,"Global")
        set(#SpinComments,$nothing,"Global")
    }
}
define PostModInfoCloser(#RunPostModInfoCloser) {
    wait(2)
    plugin command("ExBrowser.dll", "ExBrowser Wait For Dom Ready", 10)
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/main/div[2]/button")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div[2]/button")
        }
    }
    wait(2)
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://div[@tabindex=\"0\"][.=\"Not Now\"]")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://div[@tabindex=\"0\"][.=\"Not Now\"]")
        }
    }
    wait(2)
    set(#close_info,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"(?!<span\\sclass=\")[a-z\\s0-9_]+(?=\">✕)"),"Global")
    plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@class=\"{#close_info}\"][.=\"?\"]")
}
define ClientFeedback(#RunClientFeedback) {
    set(#ResponceEmail,$nothing,"Global")
    set(#EmailBody,$nothing,"Global")
    set(#ResponceEmail,$plugin function("Advanced Dialog.dll", "$prompt dialog", "Email Responce Feedback", "Enter a email you would like us to use to send a response", "", "False", 100, "", "Sample 2"),"Global")
    if($comparison(#ResponceEmail,"= Equals",$nothing)) {
        then {
            alert("Please fill in a response email to use the client portal.")
        }
        else {
            set(#EmailBody,$plugin function("Advanced Dialog.dll", "$text box dialog", "Error Reporting - Feedback - Suggestions - Ideas", #EmailBody, "False", "True", "False", "True", "True,False,False", "525,300", "False", 000000, "FF0000,000000", "FFF3C1C1,000000", "FF778ABD,000000", "Center App"),"Global")
            if($comparison(#EmailBody,"= Equals",$nothing)) {
                then {
                    alert("Feedback Request Canceled!")
                }
                else {
                    set(#RanIDNum,$plugin function("Advanced Data Text File.dll", "$random", 1000, 9000, "Long", "#"),"Global")
                    plugin command("emailplugin.dll", "send smtp email", "smtp-pulse.com", 465, "support@softwareautomation.org", "pN9mjSJrbi", "support@softwareautomation.org", "Client Feedback", "Insta Promoter Client Feedback: Issue ID: {#RanIDNum}", "<html>
<head>
<body>
<p>Insta Promoter Client Feedback: Issue ID: {#RanIDNum} </p>
<p>{#EmailBody} </p>
<p>Client Response Email: {#ResponceEmail} </p>
</body>
</head>
</html>", "feedback@softwareautomation.org", "html", "yes")
                    set(#sent,$plugin function("emailplugin.dll", "$smtp last message"),"Global")
                    wait(1)
                    if($comparison(#sent,"= Equals","success")) {
                        then {
                            plugin command("emailplugin.dll", "send smtp email", "smtp-pulse.com", 465, "support@softwareautomation.org", "pN9mjSJrbi", "support@softwareautomation.org", "Client Feedback", "Insta Promoter Client Feedback: Issue ID: {#RanIDNum}", "<html>
<head>
<body>
<p>Insta Promoter Client Feedback: Issue ID: {#RanIDNum} </p>
<p>Your feedback through the client portal has been received. 
Thank you for contacting Software Automation. 
If a response is required you will hear from us shortly. </p>
<p><a href=\"https://softwareautomation.org/\">softwareautomation.org</a></p>
</body>
</head>
</html>", #ResponceEmail, "html", "yes")
                            alert("Thank you for your feedback, you will hear from us shortly.")
                        }
                    }
                }
            }
        }
    }
}
define LoadDataFolderPath(#RunLoadDataFolderPath) {
    comment("This loads the documents data 
folder path and runs from the 
change log onload command.")
    set(#temp_path,$plugin function("Advanced Data Text File.dll", "$get folders", $special folder("My Documents"), "False", "True"),"Global")
    if($contains(#temp_path,"Insta Promoter Data Folder")) {
        then {
            set(#ipdf_path,"{$special folder("My Documents")}\\Insta Promoter Data Folder","Global")
        }
    }
    set(#temp_path,$nothing,"Global")
}
define FATAL ERROR THROUGH(#RUN_FATAL_ERROR_THROUGH) {
    if($comparison(#random_comment,"= Equals","list doesnt exist")) {
        then {
            thread {
                ListDoesntExist(#RunListDoesntExist)
            }
            set(#FATAL_ERROR,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Warning: Comment \"list doesn\'t exist\" please contact support.", "FATAL ERROR", "OK", "Warning", "ServiceNotification", "Button 2"),"Global")
            ClientFeedback(#RunClientFeedback)
            stop script
        }
    }
}
define CloseInfoBox(#RunCloseInfoBox) {
    if($plugin function("ExBrowser.dll", "$ExBrowser Element Exist", "x://span[@id=\"react-root\"]/section/div/span")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Move Mouse", "x://span[@id=\"react-root\"]/section/div/span")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/div/span")
            plugin command("ExBrowser.dll", "ExBrowser Scroll Browser", "-10000", "-10000")
        }
    }
}
