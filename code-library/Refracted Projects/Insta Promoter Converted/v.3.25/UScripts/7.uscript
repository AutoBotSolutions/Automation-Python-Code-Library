define ValidateNumScrape(#RunValidateNumScrape) {
    if($comparison(#NumberToScrape,"= Equals",$nothing)) {
        then {
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - PLEASE ENTER A NUMBER TO SCRAPE TO USE THIS FUNCTION - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            alert("Please enter a number to scrape.")
            stop script
        }
    }
}
