define ScrapeVariableListClear(#ScrapeVariableListClear) {
    if($not($file exists("{$special folder("Desktop")}\\ScrapeData"))) {
        then {
            create folder($special folder("Desktop"),"ScrapeData")
        }
    }
    plugin command("Bigtable.dll", "Clear all large list")
    set(#TagsInQueue,0,"Global")
    set(#GeoLocationQueue,0,"Global")
    set(#ScrapeFollowersQueue,0,"Global")
    set(#ScrapeCommentQueue,0,"Global")
    set(#master_delay_trigger,0,"Global")
    set(#delay_ticker,0,"Global")
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
}
define $PrefixHashTags(#PrefixHashTags) {
    set(#prefix_hashtag,$plugin function("Bigtable.dll", "Large list return", "ScrapeTags"),"Global")
    add list to list(%prefix_hashtag,$list from text(#prefix_hashtag,$new line),"Delete","Global")
    add list to list(%hashtag,$plugin function("Advanced Data Text File.dll", "$list append prefix/suffix", %prefix_hashtag, "#", ""),"Delete","Global")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeTags")
    if($comparison(#spin_scraped_tags,"= Equals","YES")) {
        then {
            set(#hashtag,$plugin function("Advanced Data Text File.dll", "$list to spin syntax", %hashtag, "\{", "\}", "|"),"Global")
            clear list(%hashtag)
            add list to list(%hashtag,$list from text(#hashtag,$new line),"Delete","Global")
        }
    }
    plugin command("Bigtable.dll", "ubot list to large list", "ScrapeTags", %hashtag)
    save to file("{$special folder("Desktop")}\\ScrapeData\\Related To [{#ScrapeTag}] Tags.txt",$plugin function("Bigtable.dll", "Large list return", "ScrapeTags"))
    set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\Related To [{#ScrapeTag}] Tags.txt","Global")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeTags")
    plugin command("Bigtable.dll", "Clear large list", "TagScrape")
    clear list(%hashtag)
    clear list(%prefix_hashtag)
}
define $SpinScrapedTags(#RunSpinScrapedTags) {
    set(#hashtag,$plugin function("Bigtable.dll", "Large list return", "ScrapeTags"),"Global")
    add list to list(%hashtag,$list from text(#hashtag,$new line),"Delete","Global")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeTags")
    set(#hashtag,$plugin function("Advanced Data Text File.dll", "$list to spin syntax", %hashtag, "\{", "\}", "|"),"Global")
    clear list(%hashtag)
    add list to list(%hashtag,$list from text(#hashtag,$new line),"Delete","Global")
    plugin command("Bigtable.dll", "ubot list to large list", "ScrapeTags", %hashtag)
    save to file("{$special folder("Desktop")}\\ScrapeData\\All [{#ScrapeTag}] Tags.txt",$plugin function("Bigtable.dll", "Large list return", "ScrapeTags"))
    set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\All [{#ScrapeTag}] Tags.txt","Global")
}
define $RemoveNonTags(#RunRemoveNonTags) {
    set(#position,0,"Global")
    loop($plugin function("Bigtable.dll", "Large list total", "ScrapeTags")) {
        if($not($contains($plugin function("Bigtable.dll", "Large list item", "ScrapeTags", #position),"#"))) {
            then {
                plugin command("Bigtable.dll", "Large list Remove item", "ScrapeTags", #position)
                decrement(#position)
            }
        }
        increment(#position)
    }
}
