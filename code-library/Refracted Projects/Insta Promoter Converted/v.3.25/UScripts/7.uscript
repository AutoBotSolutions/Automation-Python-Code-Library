define TagsScraperFour(#TagsScraperFour) {
    set(#run_master_delay,$master_delay_timers(#run_master_delay),"Global")
    set(#target_user,$plugin function("Bigtable.dll", "Large list item", "TagScrape", #TagsInQueuePos),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING REQUEST TO ID: [{#target_user}] KEYWORD [{#ScrapeTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/p/{#target_user}/?tagged={#ScrapeTag}")
    plugin command("ExBrowser.dll", "ExBrowser Wait For Element", "x://a[@href=\"/about/us/\"][.=\"About us\"]", "Appear", 5)
    if($comparison(#ScrapeTagsOption,"= Equals","Scrape All Tags")) {
        then {
            plugin command("Bigtable.dll", "large List from Regex", "ScrapeTags", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!/explore/tags/[.a-z_]+\\/\">)[@#.a-z0-9_]+(?=</a>)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "ScrapeTags")
            set(#RunRemoveNonTags,$RemoveNonTags(#RunRemoveNonTags),"Global")
            save to file("{$special folder("Desktop")}\\ScrapeData\\All [{#ScrapeTag}] Tags.txt",$plugin function("Bigtable.dll", "Large list return", "ScrapeTags"))
            set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\All [{#ScrapeTag}] Tags.txt","Global")
            set(#TagsInQueue,$plugin function("Bigtable.dll", "Large list total", "ScrapeTags"),"Global")
        }
    }
    if($comparison(#ScrapeTagsOption,"= Equals","Scrape Related Tags")) {
        then {
            plugin command("Bigtable.dll", "large List from Regex", "ScrapeTags", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\\/explore\\/tags\\/){#ScrapeTag}\\w+(?=\\/\">#)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "ScrapeTags")
            set(#TagsInQueue,$plugin function("Bigtable.dll", "Large list total", "ScrapeTags"),"Global")
        }
    }
    if($comparison(#ScrapeTagsOption,"= Equals","Scrape Top Post Tags")) {
        then {
            plugin command("Bigtable.dll", "large List from Regex", "ScrapeTags", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\\/explore\\/tags\\/){#ScrapeTag}\\w+(?=\\/\">#)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "ScrapeTags")
            set(#TagsInQueue,$plugin function("Bigtable.dll", "Large list total", "ScrapeTags"),"Global")
        }
    }
    if($comparison($plugin function("Bigtable.dll", "Large list total", "ScrapeTags"),"= Equals",$nothing)) {
        then {
            thread {
                AppListScrapeingFailed(#RunAppListScrapeingFailed)
            }
        }
    }
    increment(#TagsInQueuePos)
    increment(#master_delay_trigger)
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
    set(#run_delay_after,$delay_after_action(#run_delay_after),"Global")
    if($comparison($plugin function("Bigtable.dll", "Large list total", "ScrapeTags"),">= Greater than or equal to",#NumberToScrape)) {
        then {
            if($comparison(#ScrapeTagsOption,"= Equals","Scrape Related Tags")) {
                then {
                    set(#PrefixHashTags,$PrefixHashTags(#PrefixHashTags),"Global")
                }
            }
            if($both($comparison(#ScrapeTagsOption,"= Equals","Scrape All Tags"),$comparison(#spin_scraped_tags,"= Equals","YES"))) {
                then {
                    set(#RunSpinScrapedTags,$SpinScrapedTags(#RunSpinScrapedTags),"Global")
                }
            }
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SOFTWARE STOP SCRAPEING TAGS TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            stop script
        }
    }
}
