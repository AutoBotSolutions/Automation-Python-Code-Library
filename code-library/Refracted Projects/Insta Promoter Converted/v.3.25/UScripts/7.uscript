define ScrapeLikesFour(#RunScrapeLikesFour) {
    set(#run_master_delay,$master_delay_timers(#run_master_delay),"Global")
    set(#target_key,$plugin function("Bigtable.dll", "Large list item", "ScrapeUsers", #ScrapeUsersPos),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING REQEST TO TAG: [{#target_key}] KEYWORD [{#ScrapelikeTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/p/{#target_key}/?tagged={#ScrapelikeTag}")
    if($not($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis"))) {
        comment("wait with wait loop breakout")
        then {
            set(#wait_breakout,0,"Global")
            set(#wait_trigger,0,"Global")
            loop while($comparison(#wait_trigger,"= Equals",0)) {
                wait(0.1)
                increment(#wait_breakout)
                if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis")) {
                    then {
                        set(#wait_trigger,1,"Global")
                    }
                    else if($comparison(#wait_breakout,">= Greater than or equal to",100)) {
                        increment(#wait_trigger)
                    }
                }
            }
        }
    }
    wait(1)
    if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"liked_by")) {
        then {
            set(#class,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"(?!<a\\sclass=\")[_a-z0-9\\s]+(?=\"\\shref=\"\\/p\\/{#target_key}\\/liked_by\\/\"><span>[,0-9.]+<\\/span>\\slikes<\\/a>)"),"Global")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://a[@class=\"{#class}\"]")
        }
        else {
            comment("Fallback method, they may change it to")
            set(#class,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"(?!<a\\sclass=\")[.a-z0-9_\\s]+(?=\"\\shref=\"#\"\\srole=\"button\"><span>)"),"Global")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://a[@class=\"{#class}\"]")
        }
    }
    wait(1)
    plugin command("Bigtable.dll", "large List from Regex", "target_user", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\"\\shref=\"\\/)[a-z.0-9_]+(?=\\/\"\\sstyle=\"width:\\s30px;)", "add")
    plugin command("Bigtable.dll", "large List from Regex", "target_user", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!title=\"[.a-z_0-9]+\"\\shref=\"\\/)[.a-z_0-9]+(?=\\/\">[.a-z_0-9]+<\\/a>)", "add")
    plugin command("Bigtable.dll", "Large list Remove duplicates", "target_user")
    set(#LikesScrapeQueue,$plugin function("Bigtable.dll", "Large list total", "target_user"),"Global")
    save to file("{$special folder("Desktop")}\\ScrapeData\\[{#ScrapelikeTag}] Likes.txt",$plugin function("Bigtable.dll", "Large list return", "target_user"))
    set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\[{#ScrapelikeTag}] Likes.txt","Global")
    if($comparison($plugin function("Bigtable.dll", "Large list total", "target_user"),"= Equals",$nothing)) {
        then {
            thread {
                AppListScrapeingFailed(#RunAppListScrapeingFailed)
            }
        }
    }
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - USERS SCRAPED TO LIST = [{#ScrapelikeTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
    increment(#ScrapeUsersPos)
    increment(#master_delay_trigger)
    set(#run_delay_after,$delay_after_action(#run_delay_after),"Global")
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Comments")) {
        then {
            if($comparison($plugin function("Bigtable.dll", "Large list total", "comment_scrape"),">= Greater than or equal to",#NumberToScrape)) {
                then {
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
                    stop script
                }
            }
        }
    }
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Commenters")) {
        then {
            if($comparison($plugin function("Bigtable.dll", "Large list total", "target_user"),">= Greater than or equal to",#NumberToScrape)) {
                then {
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
                    stop script
                }
            }
        }
    }
    if($comparison(#ScrapeUsersPos,">= Greater than or equal to",#NumberToScrape)) {
        then {
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
            stop script
        }
    }
}
define ScrapeLikesFive(#RunScrapeLikesFive) {
    comment("SCrape likes from url")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeUsers")
    plugin command("Bigtable.dll", "Clear large list", "target_user")
    set(#delay_ticker,0,"Global")
    set(#master_delay_trigger,0,"Global")
    set(#LikesScrapeQueue,0,"Global")
    set(#run_master_delay,$master_delay_timers(#run_master_delay),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING REQEST TO TAG: [{#target_key}] KEYWORD [{#ScrapelikeTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
    var textarea = document.getElementById(\'textarea_id\');
    textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", #ScrapelikeTag)
    if($not($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis"))) {
        comment("wait with wait loop breakout")
        then {
            set(#wait_breakout,0,"Global")
            set(#wait_trigger,0,"Global")
            loop while($comparison(#wait_trigger,"= Equals",0)) {
                wait(0.1)
                increment(#wait_breakout)
                if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis")) {
                    then {
                        set(#wait_trigger,1,"Global")
                    }
                    else if($comparison(#wait_breakout,">= Greater than or equal to",100)) {
                        increment(#wait_trigger)
                    }
                }
            }
        }
    }
    wait(1)
    if($contains($plugin function("ExBrowser.dll", "$ExBrowser URL"),"tagged")) {
        then {
            set(#target_key,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser URL"),"(?!https://www.instagram.com/p/)[-a-zA-Z0-9_]+(?=\\/\\?tagged=\\w+)"),"Global")
        }
        else {
            set(#target_key,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser URL"),"(?<=https://www.instagram.com/p/)[-a-zA-Z0-9_]+(?=\\/)"),"Global")
        }
    }
    if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"liked_by")) {
        then {
            set(#class,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"(?!<a\\sclass=\")[_a-z0-9\\s]+(?=\"\\shref=\"\\/p\\/{#target_key}\\/liked_by\\/\"><span>[,0-9.]+<\\/span>\\slikes<\\/a>)"),"Global")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://a[@class=\"{#class}\"]")
