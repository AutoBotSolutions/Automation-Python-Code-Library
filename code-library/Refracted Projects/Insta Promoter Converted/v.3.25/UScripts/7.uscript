define FollowingFollowersScrapeOne(#FollowingFollowersScrapeOne) {
    plugin command("Bigtable.dll", "Clear large list", "ScrapeUsers")
    CloseInfoBox(#RunCloseInfoBox)
    set(#delay_ticker,0,"Global")
    set(#master_delay_trigger,0,"Global")
    set(#ScrapeFollowersQueue,0,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING BROWSER REQUEST TO USER: [{#TargetUsername}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/{#TargetUsername}/")
    plugin command("ExBrowser.dll", "ExBrowser Wait For Element", "x://span[@id=\"react-root\"]/section/footer/div/span", "Appear", 5)
    if($comparison(#ScrapeUserOption,"= Equals","Scrape Users Followers")) {
        then {
            thread {
                AppRunningModule(#RunAppRunningModule)
                set(#ActiveFunction,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=[Running Scrape Module Function] Scrape Followers Function Activated&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
            }
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/article/header/section/ul/li[2]/a")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/ul/li[2]/a")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/ul/li[2]/a/span")
        }
        else if($comparison(#ScrapeUserOption,"= Equals","Scrape Users Following")) {
            thread {
                AppRunningModule(#RunAppRunningModule)
                set(#ActiveFunction,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=[Running Scrape Module Function] Scrape Following Function Activated&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
            }
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/article/header/section/ul/li[3]/a")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/ul/li[3]/a")
            plugin command("ExBrowser.dll", "ExBrowser Click", "x://span[@id=\"react-root\"]/section/main/div/header/section/ul/li[3]/a/span")
        }
        else {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - PLEASE SELECT A SCRAPE OPTION TO USE THE SCRAPE SOFTWARE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            stop script
        }
    }
    plugin command("ExBrowser.dll", "ExBrowser Wait For Element", "x://html/body/div[4]/div/div[2]/div/div[1]", "Appear", 5)
    set(#inc_num,5,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING SCRAPE REQUEST TO USER: [{#TargetUsername}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    wait(2)
    set(#remove_element,$find regular expression($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"(?!<ul\\sclass=\"[A-Z-a-z_0-9\\s]+\"><div\\sclass=\")[A-Z-a-z_0-9\\s]+(?=\"><li\\sclass=\"[A-Z-a-z_0-9\\s]+\"><div\\sclass)"),"Global")
}
define FollowingFollowersScrapeTwo(#FollowingFollowersScrapeTwo) {
    plugin command("ExBrowser.dll", "ExBrowser Wait For Element Enabled", "x://html/body/div[3]/div/div[2]/div/div[2]/ul/div/li[*]", "Wait until Enabled", 5)
    loop(13) {
        plugin command("Bigtable.dll", "large List from Regex", "ScrapeUsers", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\"\\shref=\"\\/)[a-z.0-9_]+(?=\\/\"\\sstyle=\"width:\\s30px;)", "add")
        plugin command("ExBrowser.dll", "ExBrowser Change Attribute", "x://html/body/div[3]/div/div[2]/div/div[2]/ul/div/li[*]", "innertext", "")
        plugin command("ExBrowser.dll", "ExBrowser Scroll To Element", "x://a[@style=\"width: 30px; height: 30px;\"]")
    }
    plugin command("Bigtable.dll", "Large list Remove duplicates", "ScrapeUsers")
    set(#ScrapeFollowersQueue,$plugin function("Bigtable.dll", "Large list total", "ScrapeUsers"),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SCRAPE QUEUE FOR USER [{#TargetUsername}] TOTAL = [{#ScrapeFollowersQueue}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Change Attribute", "x://div[@class=\"{#remove_element}\"]", "innertext", "")
}
define FollowingFollowersScrapeThree(#FollowingFollowersScrapeThree) {
    save to file("{$special folder("Desktop")}\\ScrapeData\\[{#TargetUsername}].txt",$plugin function("Bigtable.dll", "Large list return", "ScrapeUsers"))
    set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\[{#TargetUsername}].txt","Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - LIST AUTO TRANSFERED TO TARGET MODULE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SCRAPED LIST SAVED OUTPUT TO [Desktop\\ScrapeData\\[{#TargetUsername}].txt] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    if($comparison($plugin function("Bigtable.dll", "Large list total", "ScrapeUsers"),"= Equals",$nothing)) {
        then {
            thread {
                AppListScrapeingFailed(#RunAppListScrapeingFailed)
            }
        }
    }
    plugin command("Bigtable.dll", "Clear large list", "ScrapeUsers")
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
}
define CommentersCommentScrapeOne(#CommentersCommentScrapeOne) {
    CloseInfoBox(#RunCloseInfoBox)
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Commenters")) {
        then {
            thread {
                AppRunningModule(#RunAppRunningModule)
                set(#ActiveFunction,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=[Running Scrape Module Function] Scrape Commenter's Function Activated&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
            }
        }
    }
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Comments")) {
        then {
            thread {
                AppRunningModule(#RunAppRunningModule)
                set(#ActiveFunction,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=[Running Scrape Module Function] Scrape Comments Function Activated&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
            }
        }
    }
    set(#ScrapeCommTag,$replace(#ScrapeCommTag,"#",""),"Global")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeUsers")
    plugin command("Bigtable.dll", "Clear large list", "target_user")
    set(#delay_ticker,0,"Global")
    set(#master_delay_trigger,0,"Global")
    set(#ScrapeCommentQueue,0,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING BROWSER REQUEST TO TAG: [{#ScrapeCommTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/explore/tags/{#ScrapeCommTag}/")
    plugin command("ExBrowser.dll", "ExBrowser Wait For Element", "x://span[@id=\"react-root\"]/section/main/article/div[1]/h2", "Appear", 5)
    CommTagNavFallBack(#RunScrapeCommTag)
    if($comparison(#top_posts,"= Equals","REMOVE")) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - REMOVE TOP POST OPTION SELECTED - REMOVING POPULAR POSTS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            comment("REMOVES Top Posts OR Populare posts on user request")
            plugin command("ExBrowser.dll", "ExBrowser Change Attribute", "x://span[@id=\"react-root\"]/section/main/article/div[1]/div", "innertext", "")
        }
    }
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SCRAPEING PROSSES STARTED FOR TAG: [{#ScrapeCommTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define CommentersCommentScrapeTwo(#CommentersCommentScrapeTwo) {
    plugin command("Bigtable.dll", "large List from Regex", "ScrapeUsers", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!<a\\shref=\"\\/p\\/)[A-Z_a-z0-9]\{9,14\}(?=\\/\\?tagged=)", "add")
    plugin command("Bigtable.dll", "Large list Remove duplicates", "ScrapeUsers")
