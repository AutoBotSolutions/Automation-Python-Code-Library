                }
            }
        }
    }
    plugin command("Bigtable.dll", "large List from Regex", "target_user", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\\s\\(@)[a-z.0-9_-]+(?=\\)\\son\\sI)", "add")
    plugin command("Bigtable.dll", "Large list Remove duplicates", "target_user")
