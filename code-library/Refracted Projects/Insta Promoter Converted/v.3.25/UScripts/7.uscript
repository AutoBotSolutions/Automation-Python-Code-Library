define CommentersCommentScrapeThree(#CommentersCommentScrapeThree) {
    set(#ScrapeCommentQueue,0,"Global")
    plugin command("Bigtable.dll", "Clear large list", "target_user")
    plugin command("Bigtable.dll", "Clear large list", "comment_scrape")
    set(#ScrapeUsersPos,0,"Global")
}
define CommentersCommentScrapeFour(#CommentersCommentScrapeFour) {
    set(#run_master_delay,$master_delay_timers(#run_master_delay),"Global")
    set(#target_key,$plugin function("Bigtable.dll", "Large list item", "ScrapeUsers", #ScrapeUsersPos),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SENDING REQEST TO TAG: [{#target_key}] KEYWORD [{#ScrapeCommTag}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/p/{#target_key}/?tagged={#ScrapeCommTag}")
    if($not($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis"))) {
        comment("wait with wait loop breakout")
        then {
            set(#wait_breakout,0,"Global")
            set(#wait_trigger,0,"Global")
            loop while($comparison(#wait_trigger,"= Equals",0)) {
                wait(0.1)
                increment(#wait_breakout)
                if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"coreSpriteOptionsEllipsis")) {
                    then {
                        set(#wait_trigger,1,"Global")
                    }
                    else if($comparison(#wait_breakout,">= Greater than or equal to",100)) {
                        increment(#wait_trigger)
                    }
                }
            }
        }
    }
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Commenters")) {
        then {
            plugin command("Bigtable.dll", "large List from Regex", "target_user", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!\",\"username\":\")[a-z.0-9_]+(?=\"\}\}\})", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "target_user")
            save to file("{$special folder("Desktop")}\\ScrapeData\\[{#ScrapeCommTag}] Commenters.txt",$plugin function("Bigtable.dll", "Large list return", "target_user"))
            set(#loaded_list,"{$special folder("Desktop")}\\ScrapeData\\[{#ScrapeCommTag}] Commenters.txt","Global")
            set(#ScrapeCommentQueue,$plugin function("Bigtable.dll", "Large list total", "target_user"),"Global")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - USERS SCRAPED TO LIST = [{#ScrapeCommentQueue}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            if($comparison($plugin function("Bigtable.dll", "Large list total", "target_user"),"= Equals",$nothing)) {
                then {
                    thread {
                        AppListScrapeingFailed(#RunAppListScrapeingFailed)
                    }
                }
            }
        }
    }
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Comments")) {
        then {
            plugin command("Bigtable.dll", "large List from Regex", "comment_scrape", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!<span>)[a-zA-Z!@#$%^&*()0-9\\s+]+(?=(?:\\uD83C[\\uDF00-\\uDFFF])|(?:\\uD83D[\\uDC00-\\uDDFF])<\\/span>)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "comment_scrape")
            plugin command("Bigtable.dll", "large List from Regex", "comment_scrape", $plugin function("ExBrowser.dll", "$ExBrowser Document Text"), "(?!<span><span>)[a-zA-Z!@#$%^&*()0-9\\s+]+(?=<\\/span><\\/span>)", "add")
            plugin command("Bigtable.dll", "Large list Remove duplicates", "comment_scrape")
            save to file("{$special folder("Desktop")}\\ScrapeData\\[{#ScrapeCommTag}] Comments.txt",$plugin function("Bigtable.dll", "Large list return", "comment_scrape"))
            set(#comment_file_list,"{$special folder("Desktop")}\\ScrapeData\\[{#ScrapeCommTag}] Comments.txt","Global")
            set(#ScrapeCommentQueue,$plugin function("Bigtable.dll", "Large list total", "comment_scrape"),"Global")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - USERS SCRAPED TO LIST = [{#ScrapeCommentQueue}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            if($comparison($plugin function("Bigtable.dll", "Large list total", "comment_scrape"),"= Equals",$nothing)) {
                then {
                    thread {
                        AppListScrapeingFailed(#RunAppListScrapeingFailed)
                    }
                }
            }
        }
    }
    increment(#ScrapeUsersPos)
    increment(#master_delay_trigger)
    set(#run_delay_after,$delay_after_action(#run_delay_after),"Global")
    set(#ClearLogSystem,$ClearLogSystem(#LogClearCommand),"Global")
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Comments")) {
        then {
            if($comparison($plugin function("Bigtable.dll", "Large list total", "comment_scrape"),">= Greater than or equal to",#NumberToScrape)) {
                then {
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    stop script
                }
            }
        }
    }
    if($comparison(#ScrapeCommentOptions,"= Equals","Scrape Commenters")) {
        then {
            if($comparison($plugin function("Bigtable.dll", "Large list total", "target_user"),">= Greater than or equal to",#NumberToScrape)) {
                then {
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    stop script
                }
            }
        }
    }
    if($comparison(#ScrapeUsersPos,">= Greater than or equal to",#NumberToScrape)) {
        then {
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SOFTWARE STOP SCRAPEING TO LIST COMPLETE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            stop script
        }
    }
}
define ScrapeGeoLocationOne(#ScrapeGeoLocationOne) {
    CloseInfoBox(#RunCloseInfoBox)
    thread {
        AppRunningModule(#RunAppRunningModule)
        set(#ActiveFunction,$plugin function("HTTP post.dll", "$http get", "http://app.tracking.softwareautomation.org/appstats/piwik.php?&idsite=1&rec=1&_id={#session_id}&rand={#anti_cache}&apiv=1&action_name=[Running Scrape Module Function] Scrape GeoLocation Function Activated&url=http://app.tracking.org", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0) Gecko/20100101 Firefox/60.0", "", "", 20),"Global")
    }
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - GEO LOCATION TARGETING STARTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    plugin command("Bigtable.dll", "Clear large list", "target_user")
    plugin command("Bigtable.dll", "Clear large list", "ScrapeUsers")
    set(#delay_ticker,0,"Global")
    set(#GeoLocationQueue,0,"Global")
    set(#master_delay_trigger,0,"Global")
    if($not($contains($plugin function("ExBrowser.dll", "$ExBrowser URL"),#GeoLocation))) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser Navigate", "https://www.instagram.com/explore/locations/{#GeoLocation}")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PLEASE SELECT YOUR TARGET CITIE FROM THE PAGE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
        else {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PLEASE SELECT YOUR TARGET CITIE FROM THE PAGE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
    loop while($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"Cities")) {
        wait(0.1)
    }
    if($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"Locations in")) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PLEASE SELECT YOUR TARGET LOCATION FROM THE PAGE - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            loop while($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"Locations in")) {
                wait(0.1)
            }
        }
    }
    loop while($not($contains($plugin function("ExBrowser.dll", "$ExBrowser Document Text"),"Top posts"))) {
        wait(0.1)
    }
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TARGET LOCATION SCRAPING PROCESS HAS BEGUN - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    if($comparison(#top_posts,"= Equals","REMOVE")) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - REMOVE TOP POST OPTION SELECTED - REMOVING POPULAR POSTS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            comment("REMOVES Top Posts OR Populare posts on user request")
            plugin command("ExBrowser.dll", "ExBrowser Change Attribute", "x://span[@id=\"react-root\"]/section/main/article/div[1]/div", "innertext", "")
        }
    }
}
