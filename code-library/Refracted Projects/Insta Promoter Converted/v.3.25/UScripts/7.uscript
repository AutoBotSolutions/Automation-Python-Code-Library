define ScrapeGeoLocationFour(#ScrapeGeoLocationFour) {
    set(#run_master_delay,$master_delay_timers(#run_master_delay),"Global")
    set(#target_user,$plugin function("Bigtable.dll", "Large list item", "ScrapeUsers", #ScrapeUsersPos),"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
