define TargetTestCellDisabled(#RunTargetTestCellDisabled) {
    if($comparison(#enable_following,"= Equals",$true)) {
        then {
            set(#get_follow_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #FollowRow, 3),"Global")
        }
    }
    if($comparison(#enable_likeing,"= Equals",$true)) {
        then {
            set(#get_like_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #LikesRow, 4),"Global")
        }
    }
    if($comparison(#enable_commenting,"= Equals",$true)) {
        then {
            set(#get_comment_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #CommentsRow, 5),"Global")
        }
    }
    if($comparison(#enable_actioning,"= Equals",$true)) {
        then {
            set(#get_actions_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #ActionRow, 6),"Global")
        }
    }
    if($comparison(#unfollow_off_on,"= Equals",$true)) {
        then {
            set(#get_unfollow_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #UnfollowRow, 8),"Global")
        }
    }
    comment("TESTING CELL DATA FOR DISABLED END CRITERIA")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TESTING CELL DATA FOR DISABLED END CRITERIA - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define TargetCellRoateTrigger(#RunTargetCellRoateTrigger) {
    if($comparison(#RotateOnEndCriteria,"= Equals","YES")) {
        then {
            if($comparison(#SettingsCounter,"<= Less than or equal to",0)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ROTATE ON END CRITERIA TRIGGER TRIPPED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    TargetCellStopTrigger(#RunTargetCellStopTrigger)
                    set(#RunTargetSuccAccRotation,$TargetSuccAccRotation(#RunTargetSuccAccRotation),"Global")
                }
            }
        }
    }
}
define TargetCellStopTrigger(#RunTargetCellStopTrigger) {
    if($comparison(#StopBotOnEndCriteria,"= Equals","YES")) {
        then {
            if($comparison(#SettingsCounter,"<= Less than or equal to",0)) {
                then {
                    if($comparison(#account_row,">= Greater than or equal to",$table total rows(&accounts_table))) {
                        then {
                            DateTimeLogStamp(#RunDateTimeLogStamp)
                            run javascript("textarea_id.value += \"{#time} - SOFTWARE STTOPED - STOP ON END CRITERIA SETTING SELECTED AND TRIGGERED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                            stop script
                        }
                    }
                }
            }
        }
    }
}
define $TargetSuccessionStop(#RunTargetSuccessionStop) {
    comment("succession stop function if running just one account")
    set(#counters_total,$add($add($add(#follow_list_counter,#likeing_counter),#commeing_counter),#unfollow_list_counter),"Global")
    if($comparison($table total rows(&accounts_table),"= Equals",1)) {
        then {
            if($comparison(#counters_total,">= Greater than or equal to",#succession_stop_bot_at)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SUCCESSION SINGLE ACCOUNT STOP TRIGGER CRITERIA MET - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    set(#FollowColor,"#d9d9d9","Global")
                    set(#LikeColor,"#d9d9d9","Global")
                    set(#CommentColor,"#d9d9d9","Global")
                    set(#ActionsColor,"#d9d9d9","Global")
                    set(#AutoFollowColor,"#d9d9d9","Global")
                    set(#UnfollowColor,"#d9d9d9","Global")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SUCCESSION STOP CRITERIA HAS BEEN MET, SUCCESSION BOT STOPPED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
    if($comparison($table total rows(&accounts_table),"> Greater than",1)) {
        then {
            if($comparison(#AllFunctionCounter,">= Greater than or equal to",#succession_stop_bot_at)) {
                then {
                    comment("succession stop function if running multiple accounts")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SUCCESSION MULTIPLE ACCOUNT STOP TRIGGER CRITERIA MET - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    set(#FollowColor,"#d9d9d9","Global")
                    set(#LikeColor,"#d9d9d9","Global")
                    set(#CommentColor,"#d9d9d9","Global")
                    set(#ActionsColor,"#d9d9d9","Global")
                    set(#AutoFollowColor,"#d9d9d9","Global")
                    set(#UnfollowColor,"#d9d9d9","Global")
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - SUCCESSION STOP CRITERIA HAS BEEN MET, SUCCESSION BOT STOPPED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
}
define $TargetSuccAccRotation(#RunTargetSuccAccRotation) {
    set(#counters_total,$add($add($add(#follow_list_counter,#likeing_counter),#commeing_counter),#unfollow_list_counter),"Global")
    if($comparison(#rotate_account_at,"!= Does not equal","X")) {
        then {
            if($comparison(#counters_total,">= Greater than or equal to",#rotate_account_at)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time}  - SOFTWARE ROTATION - SUCCESSION ACCOUNT ROTATION CRITERIA HAS BEEN MET, ROTATING TO NEXT ACCOUNT IN LIST - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    if($comparison(#account_row,"> Greater than",$subtract($table total rows(&accounts_table),1))) {
                        then {
                            set(#RunRotationAccountRest,$RotationAccountRest(#RunRotationAccountRest),"Global")
                        }
                    }
                    InstaPromoterDriverKiller(#RunInstaPromoterDriverKiller)
                    plugin command("ExBrowser.dll", "ExBrowser Delete All Cookies")
                    set(#RunRotationLogin,$RotationLoginFunction(#RunRotationLogin),"Global")
                    TargetSuccessionSetup(#RunTargetSuccessionSetup)
                    TargetRestCellOperator(#RunRestCellOperator)
                }
            }
        }
    }
    if($comparison(#RotateOnEndCriteria,"= Equals","YES")) {
        then {
            if($comparison(#SettingsCounter,"<= Less than or equal to",0)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ROTATE ON END CRITERIA MET - ROTATING TO NEXT ACCOUNT - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    if($comparison(#account_row,"> Greater than",$subtract($table total rows(&accounts_table),1))) {
                        then {
                            set(#RunRotationAccountRest,$RotationAccountRest(#RunRotationAccountRest),"Global")
                        }
                    }
                    InstaPromoterDriverKiller(#RunInstaPromoterDriverKiller)
                    plugin command("ExBrowser.dll", "ExBrowser Delete All Cookies")
                    set(#RunRotationLogin,$RotationLoginFunction(#RunRotationLogin),"Global")
                    TargetSuccessionSetup(#RunTargetSuccessionSetup)
                    TargetRestCellOperator(#RunRestCellOperator)
                    RestTargetDisabledOperator(#RunRestTargetDisabledOperator)
                    TargetResetEnabledSetting(#ResetTargetEnabledSetting)
                    QualifySettingsCounter(#RunQualifySettingsCounter)
                }
            }
        }
    }
}
define TargetCreateStatsTable(#RunTargetCreateStatsTable) {
    clear table(&statistics)
    TargetStatisticsSetup(#RunTargetStatisticsSetup)
    loop($table total rows(&accounts_table)) {
        set(#username,$table cell(&accounts_table,#UsernameRow,0),"Global")
        set table cell(&statistics,#UsernameRow,0,#username)
        set(#password,$table cell(&accounts_table,#PasswordRow,1),"Global")
        set table cell(&statistics,#PasswordRow,1,#password)
        if($comparison(#proxy_file,"!= Does not equal","")) {
            then {
                set(#proxy,$table cell(&proxy_table,#ProxyRow,0),"Global")
            }
        }
        set table cell(&statistics,#ProxyRow,2,#proxy)
        set table cell(&statistics,#FollowRow,3,$nothing)
        set table cell(&statistics,#LikesRow,4,$nothing)
        set table cell(&statistics,#CommentsRow,5,$nothing)
        set table cell(&statistics,#ActionRow,6,$nothing)
        set table cell(&statistics,#FollowBackRow,7,$nothing)
        set table cell(&statistics,#UnfollowRow,8,$nothing)
        set table cell(&statistics,#CountersTotalRow,9,$nothing)
        set table cell(&statistics,#PostRow,10,$nothing)
        DateTimeLogStamp(#RunDateTimeLogStamp)
        run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - CREATING STATISTICS TABLE SETUP - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        TargetIncStatistics(#RunTargetIncStatistics)
    }
    TargetStatisticsSetup(#RunTargetStatisticsSetup)
}
define TargetStatisticsSetup(#RunTargetStatisticsSetup) {
    if($comparison(#RunFromProjectFolder,"= Equals","YES")) {
        then {
            CreateProjectPathPosOnStart(#RunCreateProjectPathPosOnStart)
        }
    }
    set(#UsernameRow,0,"Global")
    set(#PasswordRow,0,"Global")
    set(#ProxyRow,0,"Global")
    set(#FollowRow,0,"Global")
    set(#LikesRow,0,"Global")
    set(#CommentsRow,0,"Global")
    set(#ActionRow,0,"Global")
    set(#FollowBackRow,0,"Global")
    set(#UnfollowRow,0,"Global")
    set(#CountersTotalRow,0,"Global")
    set(#PostRow,0,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - RESETTING CELL DATA STATISTICS ROW - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define TargetIncStatistics(#RunTargetIncStatistics) {
    increment(#UsernameRow)
    increment(#PasswordRow)
    increment(#ProxyRow)
    increment(#FollowRow)
    increment(#LikesRow)
    increment(#CommentsRow)
    increment(#ActionRow)
    increment(#FollowBackRow)
    increment(#UnfollowRow)
    increment(#CountersTotalRow)
    increment(#PostRow)
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - INCREMENTING CELL DATA STATISTICS ROW - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
