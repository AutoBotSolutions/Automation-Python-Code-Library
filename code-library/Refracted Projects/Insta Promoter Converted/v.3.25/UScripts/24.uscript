define Target Succession(#RunTargetSuccession) {
    set(#infinite_loop,0,"Global")
    set(#loaded_list_pos,0,"Global")
    set(#SettingsCounter,0,"Global")
    set(#AllFunctionCounter,0,"Global")
    set(#master_delay_trigger,0,"Global")
    if($comparison(#RunFromProjectFolder,"= Equals","YES")) {
        then {
            CreateProjectPathPosOnStart(#RunCreateProjectPathPosOnStart)
            CreateProjectFilePaths(#RunCreateProjectFilePaths)
        }
    }
    TargetSettingsConfigError(#RunTargetSettingsConfigError)
    SetTriggerCountersOff(#RunSetTriggerCountersOff)
    RestTargetDisabledOperator(#RunRestTargetDisabledOperator)
    QualifySettingsCounter(#RunQualifySettingsCounter)
    TargetSuccessionSetup(#RunTargetSuccessionSetup)
    if($comparison(#RandomizeSuccession,"= Equals","YES")) {
        then {
            loop while($comparison(#infinite_loop,"= Equals",0)) {
                set(#RunTargetSuccessionLoopSetup,$TargetSuccessionLoopSetup(#RunTargetSuccessionLoopSetup),"Global")
                loop(5) {
                    set(#random_num_gen,$plugin function("Advanced Data Text File.dll", "$random", 0, 5, "Int", ""),"Global")
                }
                TargetCellRoateTrigger(#RunTargetCellRoateTrigger)
                TargetTestCellDisabled(#RunTargetTestCellDisabled)
                if($comparison(#get_follow_cell,"< Less than",#DisableFollowing)) {
                    then {
                        if($both($comparison(#random_num_gen,"= Equals",0),$comparison(#enable_following,"= Equals",$true))) {
                            then {
                                loop(#num_follow) {
                                    set(#RunTargetFollowModuleTwo,$TargetFollowModuleTwo(#RunTargetFollowModuleTwo),"Global")
                                }
                                TargetLightsRest(#RunTargetLightsRest)
                            }
                        }
                    }
                    else if($both($comparison(#enable_following,"= Equals",$true),$comparison(#DeactivateFollows,"= Equals",0))) {
                        set(#DeactivateFollows,1,"Global")
                        decrement(#SettingsCounter)
                    }
                }
                if($comparison(#get_like_cell,"< Less than",#DisableLikeing)) {
                    then {
                        if($both($comparison(#random_num_gen,"= Equals",1),$comparison(#enable_likes,"= Equals",$true))) {
                            then {
                                loop(#num_like) {
                                    set(#RunTargetLikeModuleTwo,$TargetLikeModuleTwo(#RunTargetLikeModuleTwo),"Global")
                                }
                                TargetLightsRest(#RunTargetLightsRest)
                            }
                        }
                    }
                    else if($both($comparison(#enable_likes,"= Equals",$true),$comparison(#DeactivateLikes,"= Equals",0))) {
                        set(#DeactivateLikes,1,"Global")
                        decrement(#SettingsCounter)
                    }
                }
                if($comparison(#get_comment_cell,"< Less than",#DisableCommenting)) {
                    then {
                        if($both($comparison(#random_num_gen,"= Equals",2),$comparison(#enable_commenting,"= Equals",$true))) {
                            then {
                                loop(#num_comment) {
                                    set(#RunCommentModuleTwo,$TargetCommentModuleTwo(#RunCommentModuleTwo),"Global")
                                }
                                TargetLightsRest(#RunTargetLightsRest)
                            }
                        }
                    }
                    else if($both($comparison(#enable_commenting,"= Equals",$true),$comparison(#DeactivateComments,"= Equals",0))) {
                        set(#DeactivateComments,1,"Global")
                        decrement(#SettingsCounter)
                    }
                }
                if($plugin function("Advanced Ubot.dll", "$compare 2", $comparison(#get_actions_cell,"< Less than",#DisableMutilTool), "&&", $comparison(#get_comment_cell,"< Less than",#DisableCommenting), "&&", $comparison(#get_like_cell,"< Less than",#DisableLikeing), "&&", $comparison(#get_follow_cell,"< Less than",#DisableFollowing))) {
                    then {
                        if($both($comparison(#random_num_gen,"= Equals",3),$comparison(#enable_multi_tool,"= Equals",$true))) {
                            then {
                                loop(#num_multi_actions) {
                                    set(#RunListRunActionSystemTwo,$ListMultiActionSystemTwo(#RunListRunActionSystemTwo),"Global")
                                }
                                TargetLightsRest(#RunTargetLightsRest)
                            }
                        }
                    }
                    else if($both($comparison(#enable_multi_tool,"= Equals",$true),$comparison(#DeactivateActions,"= Equals",0))) {
                        set(#DeactivateActions,1,"Global")
                        decrement(#SettingsCounter)
                    }
                }
                if($comparison(#get_unfollow_cell,"< Less than",#DisableUnfollow)) {
                    then {
                        if($both($comparison(#random_num_gen,"= Equals",4),$comparison(#enable_unfollowing,"= Equals",$true))) {
                            then {
                                loop(#num_unfollow) {
                                    set(#RunTargetUnfollowModuleTwo,$TargetUnfollowModuleTwo(#RunTargetUnfollowModuleTwo),"Global")
                                }
                                TargetLightsRest(#RunTargetLightsRest)
                            }
                        }
                    }
                    else if($both($comparison(#enable_unfollowing,"= Equals",$true),$comparison(#DeactivateUnfollows,"= Equals",0))) {
                        set(#DeactivateUnfollows,1,"Global")
                        decrement(#SettingsCounter)
                    }
                }
                TargetCellStopTrigger(#RunTargetCellStopTrigger)
            }
        }
        else {
            loop while($comparison(#infinite_loop,"= Equals",0)) {
                set(#RunTargetSuccessionLoopSetup,$TargetSuccessionLoopSetup(#RunTargetSuccessionLoopSetup),"Global")
                TargetCellRoateTrigger(#RunTargetCellRoateTrigger)
                TargetTestCellDisabled(#RunTargetTestCellDisabled)
                if($comparison(#enable_following,"= Equals",$true)) {
                    then {
                        loop(#num_follow) {
                            set(#RunTargetFollowModuleTwo,$TargetFollowModuleTwo(#RunTargetFollowModuleTwo),"Global")
                        }
                        TargetLightsRest(#RunTargetLightsRest)
                    }
                }
                if($comparison(#enable_likes,"= Equals",$true)) {
                    then {
                        loop(#num_like) {
                            set(#RunTargetLikeModuleTwo,$TargetLikeModuleTwo(#RunTargetLikeModuleTwo),"Global")
                        }
                        TargetLightsRest(#RunTargetLightsRest)
                    }
                }
                if($comparison(#enable_commenting,"= Equals",$true)) {
                    then {
                        loop(#num_comment) {
                            set(#RunCommentModuleTwo,$TargetCommentModuleTwo(#RunCommentModuleTwo),"Global")
                        }
                        TargetLightsRest(#RunTargetLightsRest)
                    }
                }
                if($comparison(#enable_multi_tool,"= Equals",$true)) {
                    then {
                        loop(#num_multi_actions) {
                            set(#RunListRunActionSystemTwo,$ListMultiActionSystemTwo(#RunListRunActionSystemTwo),"Global")
                        }
                        TargetLightsRest(#RunTargetLightsRest)
                    }
                }
                if($comparison(#enable_unfollowing,"= Equals",$true)) {
                    then {
                        loop(#num_unfollow) {
                            set(#RunTargetUnfollowModuleTwo,$TargetUnfollowModuleTwo(#RunTargetUnfollowModuleTwo),"Global")
                        }
                        TargetLightsRest(#RunTargetLightsRest)
                    }
                }
                TargetCellStopTrigger(#RunTargetCellStopTrigger)
            }
        }
    }
}
define SetTriggerCountersOff(#RunSetTriggerCountersOff) {
    set(#FollowsActive,0,"Global")
    set(#LikesActive,0,"Global")
    set(#CommentsActive,0,"Global")
    set(#ActionsActive,0,"Global")
    set(#UnfollowActive,0,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - RESETTING ACTIVE FUNCTION TRIGGERS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define QualifySettingsCounter(#RunQualifySettingsCounter) {
    if($comparison(#enable_following,"= Equals",$true)) {
        then {
            increment(#SettingsCounter)
        }
    }
    if($comparison(#enable_likes,"= Equals",$true)) {
        then {
            increment(#SettingsCounter)
        }
    }
    if($comparison(#enable_commenting,"= Equals",$true)) {
        then {
            increment(#SettingsCounter)
        }
    }
    if($comparison(#enable_multi_tool,"= Equals",$true)) {
        then {
            increment(#SettingsCounter)
        }
    }
    if($comparison(#enable_unfollowing,"= Equals",$true)) {
        then {
            increment(#SettingsCounter)
        }
    }
    if($comparison(#SettingsCounter,"= Equals",0)) {
        then {
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - YOU MUST HAVE AT LEAST ONE FUNCTION ENABLED TO USE THE SOFTWARE. - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            alert("You must have at least one function enabled to use the software.")
            stop script
        }
    }
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ENABLED SETTINGS COUNTERS TOTAL = [{#SettingsCounter}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define $TargetSuccessionStatistics(#RunTargetSuccessionStatistics) {
    TargetSetZeroOperator(#RunTargetSetZeroOperator)
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - RUNNING SUCCESSION ACCOUNT STATISTICS - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    set(#username,$table cell(&accounts_table,#UsernameRow,0),"Global")
    set table cell(&statistics,#UsernameRow,0,#username)
    set(#password,$table cell(&accounts_table,#PasswordRow,1),"Global")
    if($comparison(#proxy_file,"!= Does not equal","")) {
        then {
            set(#proxy,$table cell(&proxy_table,#ProxyRow,0),"Global")
        }
    }
    set table cell(&statistics,#ProxyRow,2,#proxy)
    if($comparison(#get_follow_cell,"< Less than",#DisableFollowing)) {
        then {
            if($comparison(#FollowsActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#FollowRow,3),"!= Does not equal","")) {
                        then {
                            set(#get_follow_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #FollowRow, 3),"Global")
                            set(#current_follows,$add(#get_follow_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_follows,"= Equals",0)) {
                        then {
                            set(#current_follows,1,"Global")
                        }
                    }
                    set table cell(&statistics,#FollowRow,3,#current_follows)
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT [{#username}] FOLLOW TOTAL = [{#current_follows}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    if($comparison(#get_like_cell,"< Less than",#DisableLikeing)) {
        then {
            if($comparison(#LikesActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#LikesRow,4),"!= Does not equal","")) {
                        then {
                            set(#get_like_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #LikesRow, 4),"Global")
                            set(#current_likes,$add(#get_like_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_likes,"= Equals",0)) {
                        then {
                            set(#current_likes,1,"Global")
                        }
                    }
                    set table cell(&statistics,#LikesRow,4,#current_likes)
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT [{#username}] LIKE TOTAL = [{#current_likes}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    if($comparison(#get_comment_cell,"< Less than",#DisableCommenting)) {
        then {
            if($comparison(#CommentsActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#CommentsRow,5),"!= Does not equal","")) {
                        then {
                            set(#get_comment_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #CommentsRow, 5),"Global")
                            set(#current_comments,$add(#get_comment_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_comments,"= Equals",0)) {
                        then {
                            set(#current_comments,1,"Global")
                        }
                    }
                    set table cell(&statistics,#CommentsRow,5,#current_comments)
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT [{#username}] COMMENT TOTAL = [{#current_comments}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    if($comparison(#get_actions_cell,"< Less than",#DisableMutilTool)) {
        then {
            if($comparison(#ActionsActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#ActionRow,6),"!= Does not equal","")) {
                        then {
                            set(#get_actions_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #ActionRow, 6),"Global")
                            set(#current_actions,$add(#get_actions_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_actions,"= Equals",0)) {
                        then {
                            set(#current_actions,1,"Global")
                        }
                    }
                    set table cell(&statistics,#ActionRow,6,#current_actions)
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT [{#username}] MULTI ACTION TOTAL = [{#current_actions}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    if($comparison(#get_followback_cell,"< Less than",#DisableFollowBack)) {
        then {
            if($comparison(#FollowBackActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#FollowBackRow,7),"!= Does not equal","")) {
                        then {
                            set(#get_followback_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #FollowBackRow, 7),"Global")
                            set(#current_follow_backs,$add(#get_followback_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_follow_backs,"= Equals",0)) {
                        then {
                            set(#current_follow_backs,1,"Global")
                        }
                    }
                    set table cell(&statistics,#FollowBackRow,7,#current_follow_backs)
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT [{#username}] FOLLOW BACK TOTAL = [{#current_follow_backs}] - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    if($comparison(#get_unfollow_cell,"< Less than",#DisableUnfollow)) {
        then {
            if($comparison(#UnfollowActive,"= Equals",1)) {
                then {
                    if($comparison($table cell(&statistics,#UnfollowRow,8),"!= Does not equal","")) {
                        then {
                            set(#get_unfollow_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #UnfollowRow, 8),"Global")
                            set(#current_unfollows,$add(#get_unfollow_cell,1),"Global")
                        }
                    }
                    if($comparison(#current_unfollows,"= Equals",0)) {
                        then {
                            set(#current_unfollows,1,"Global")
                        }
                    }
                    set table cell(&statistics,#UnfollowRow,8,#current_unfollows)
