var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                }
            }
        }
    }
    TargetTestCellDisabled(#RunTargetTestCellDisabled)
    set(#cell_counters_total,$add($add($add(#get_follow_cell,#get_like_cell),#get_comment_cell),#get_unfollow_cell),"Global")
    set table cell(&statistics,#CountersTotalRow,9,"{#cell_counters_total} (actions, follow back not included)")
    comment("Retains Any Posts Staticstics While in Sucsesstion mode
if the post bot had been ran before the sucsesstion module
this retrives the cell data and posts back into the cell")
    set(#get_post_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #PostRow, 10),"Global")
    set table cell(&statistics,#PostRow,10,#get_post_cell)
}
