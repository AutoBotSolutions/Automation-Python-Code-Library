    }
    if($file exists("{$special folder("Application")}\\temp\\0.txt")) {
        then {
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SYSTEM SETUP - INSTALLING SUPPORT DRIVERS - ACCOUNT LOGIN - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
