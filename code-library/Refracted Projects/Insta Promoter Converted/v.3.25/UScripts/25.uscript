                }
            }
            if($comparison(#post_schedule,"= Equals",$nothing)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PLEASE ADD YOUR DATE AND TIME STAMPS INTO THE POST SCHEDULED BOX - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
    if($comparison(#post_options,"= Equals","Post Now")) {
        then {
            if($comparison(#num_post_now,"= Equals",$nothing)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TO USE THE POST NOW SETTING ENTER A NUMBER IN THE BOX TO POST NOW BOX - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
            if($comparison(#stop_bot_at,"= Equals",$nothing)) {
                then {
                    DateTimeLogStamp(#RunDateTimeLogStamp)
                    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - TO USE THE POST NOW SETTING PLEASE TELL THE SOFTWARE WHEN TO STOP POSTING - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
                    plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
                    stop script
                }
            }
        }
    }
}
define StartLoginAccountRest(#RunStartLoginAccountRest) {
    clear table(&accounts_table)
    clear table(&proxy_table)
    set(#proxy_row,0,"Global")
    set(#account_row,0,"Global")
    set(#trigger_one,0,"Global")
}
define KillSwitchCheack(#KillSwitchCheack) {
    plugin command("ExBrowser.dll", "ExBrowser CleanUp", "Yes")
    set(#KillSwitch,$plugin function("ExBrowser.dll", "$ExBrowser Browser Alive"),"Global")
    loop while($comparison(#KillSwitch,"= Equals",$true)) {
        set(#KillSwitch,$plugin function("ExBrowser.dll", "$ExBrowser Browser Alive"),"Global")
    }
}
