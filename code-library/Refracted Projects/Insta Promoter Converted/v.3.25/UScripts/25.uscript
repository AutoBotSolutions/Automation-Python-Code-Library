var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("ExBrowser.dll", "ExBrowser Launcher", "Chrome", "", "{$plugin function("ExBrowser.dll", "$ExBrowser Specify Binary Location", "{$special folder("Application")}\\portable\\GoogleChromePortable-66.0.3359.139\\App\\Chrome-bin\\insta-promoter.exe")}{$plugin function("ExBrowser.dll", "$ExBrowser Set User Agent", #user_agent)}{$plugin function("ExBrowser.dll", "$ExBrowser Chrome Disable Info Bars")}{$plugin function("ExBrowser.dll", "$ExBrowser Load Browser Extension", "{$special folder("Application")}\\extensions\\WebRTC-Leak-Shield.crx")}{$plugin function("ExBrowser.dll", "$ExBrowser Load Browser Extension", "{$special folder("Application")}\\extensions\\websta-for-Instagram.crx")}")
        }
    }
