define RotationAccountRest(#RunRotationRestAccounts) {
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - ACCOUNT RESET INITIATED, CLEANING AND CLOSING CHROME - PLEASE WAIT! - ACCOUNT LOGIN - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
    set(#null3,$plugin function("ExBrowser.dll", "$ExBrowser Browser Alive"),"Global")
    if($comparison(#null3,"= Equals","true")) {
        then {
            plugin command("ExBrowser.dll", "ExBrowser CleanUp", "Yes")
        }
    }
    set(#KillSwitch,$plugin function("ExBrowser.dll", "$ExBrowser Browser Alive"),"Global")
    loop while($comparison(#KillSwitch,"= Equals",$true)) {
        set(#KillSwitch,$plugin function("ExBrowser.dll", "$ExBrowser Browser Alive"),"Global")
    }
    clear table(&accounts_table)
    clear table(&proxy_table)
    set(#proxy_row,0,"Global")
    set(#account_row,0,"Global")
    set(#trigger_one,0,"Global")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPPED - ACCOUNT RESET AND BROWSER CLOSED SUCCESSFULLY - ACCOUNT LOGIN - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
define $ExacutionRotateNextScript(#RunExacutionRotateNextScript) {
    comment("Rotate To Next Account - Rest Accounts Table")
    if($comparison(#account_row,"> Greater than",$subtract($table total rows(&accounts_table),1))) {
        then {
            set(#RunRotationRestAccounts,$RotationAccountRest(#RunRotationRestAccounts),"Global")
            if($comparison(#UsePostProjectRotation,"= Equals","YES")) {
                then {
                    set(#UploadFoldersPos,0,"Global")
                    set(#CaptionPathsPos,0,"Global")
                    set(#ProjectSettingsPathsPos,0,"Global")
                }
            }
        }
    }
    set(#RunPostRotationLoginBlock,$PostRotationLoginBlock(#RunPostRotationLoginBlock),"Global")
    set(#get_post_cell,0,"Global")
    set(#current_posts,0,"Global")
}
define RotationPostStatistics(#RunRotationPostStatistics) {
    set(#get_post_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #PostRow, 10),"Global")
    if($comparison($table cell(&statistics,#PostRow,10),"!= Does not equal","")) {
        then {
            set(#get_post_cell,$plugin function("Advanced Data Text File.dll", "$table cell get", &statistics, #PostRow, 10),"Global")
            set(#current_posts,$add(#get_post_cell,1),"Global")
        }
    }
    if($comparison(#current_posts,"= Equals",0)) {
        then {
            set(#current_posts,1,"Global")
        }
    }
    set table cell(&statistics,#PostRow,10,#current_posts)
}
