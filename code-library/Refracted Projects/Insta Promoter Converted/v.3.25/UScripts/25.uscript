    }
    if($comparison(#trigger_one,"!= Does not equal",0)) {
        then {
            increment(#PostRow)
        }
    }
    StartLogRunning(#OpenLog)
    set(#SystemUserError,$UserErrorSystem(#SystemUserError),"Global")
    wait(1)
    KillSwitchCheack(#KillSwitchCheack)
    if($not($exists(<id="textarea_id">))) {
        then {
            set(#browser ui,$read file("{$special folder("Application")}\\htui\\log-ui.html"),"Global")
