define $PostRotationLoginBlock(#RunPostRotationLoginBlock) {
    if($comparison(#UsePostProjectRotation,"= Equals","YES")) {
        then {
            comment("Rests the image upload position 
back to the top of the list when 
the accounts rest back to the top 
of the list.")
            set(#image_paths_pos,0,"Global")
            set(#image_captions_pos,0,"Global")
            if($comparison(#trigger_one,"!= Does not equal",0)) {
                then {
                    increment(#UploadFoldersPos)
                    increment(#CaptionPathsPos)
                    increment(#ProjectSettingsPathsPos)
                }
            }
            if($comparison(#trigger_one,"= Equals",0)) {
                then {
                    set(#UploadFoldersPos,0,"Global")
                    set(#CaptionPathsPos,0,"Global")
                    set(#ProjectSettingsPathsPos,0,"Global")
                }
            }
        }
    }
    if($comparison(#trigger_one,"= Equals",0)) {
        then {
            StatisticsSetup(#RunStatisticsSetup)
