        set(#RunSaveCustomFolder,$SaveCustomFolder(#RunSaveCustomFolder),"Global")
    }
    ui button("Load Settings") {
        set(#RunLoadCustomFolder,$LoadCustomFolder(#RunLoadCustomFolder),"Global")
    }
    ui stat monitor(#main ui,"")
}
ui window("Advanced Settings") {
    ui drop down("Save Tags As Spintax",",YES,NO",#spin_scraped_tags)
    ui stat monitor("<br />","")
    ui button("Open List Spintax Generator") {
        plugin command("Communication.dll", "run ubot script", "BasicCommentSpinner()")
    }
    ui stat monitor("<br />","")
    ui drop down("Popular Posts",",KEEP,REMOVE",#top_posts)
    ui stat monitor("<br />","")
    ui drop down("Show Hide Browser",",SHOW,HIDE",#ShowHideBrowser)
    ui stat monitor("<br />","")
    ui drop down("Randomize Scrape List",",YES,NO",#RandomizeScrapeList)
    ui stat monitor(#main ui,"")
    ui text box("Set User Agent String",#user_agent)
}
