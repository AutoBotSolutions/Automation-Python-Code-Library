ui button("Open Country Abbreviations pdf") {
    plugin command("Advanced Data Text File.dll", "open file/url", "https://softwareautomation.org/home/insta-promoter.html")
    wait(5)
    plugin command("Advanced Data Text File.dll", "open file/url", "https://softwareautomation.org/pdf/CountryAbbreviations.pdf")
    DateTimeLogStamp(#RunDateTimeLogStamp)
    run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - OPENING COUNTRY CODE REFFRANCE COMPLETE! - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
}
ui stat monitor("<br >","")
ui button("Open &nbsp;Settings") {
    set(#null,$plugin function("Advanced Dialog.dll", "$dropdown dialog", "Quick Settings View", "", "CLIENT PORTAL,-------------------------------,[ Post Module ],[ Succession Module ],[ Target Module ],-------------------------------,Required Files,Delay Settings,Advanced Settings,Save/Load Settings,Open List Spinner,Settings Quick View", 280, 125, "False", 000000, "FFBEEAC4,FDFEFE", "FFF3C1C1,FDFEFE", "Center App", "True", "{$special folder("Application")}\\img\\inp.ico"),"Global")
    if($comparison(#null,"= Equals","Delay Settings")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Delay Settings")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - OPENING DELAY DIALOG SETTINGS COMPLETE! - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
    if($comparison(#null,"= Equals","Required Files")) {
        then {
            StartLogRunning(#OpenLog)
            plugin command("Advanced Ubot.dll", "menu item click", "Required Files")
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - OPENING REQUIRED FILES DIALOG SETTINGS COMPLETE! - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
        }
    }
    if($comparison(#null,"= Equals","Save/Load Settings")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SAVE & LOAD SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Ubot.dll", "menu item click", "Save/Load Settings")
        }
    }
    if($comparison(#null,"= Equals","Advanced Settings")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SAVE & LOAD SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Ubot.dll", "menu item click", "Advanced Settings")
        }
    }
    if($comparison(#null,"= Equals","Open List Spinner")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - OPEN LIST SPINNER OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Communication.dll", "run ubot script", "BasicCommentSpinner()")
        }
    }
    if($comparison(#null,"= Equals","Settings Quick View")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - QUICK SETTINGS VIEW OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            QuickView3(#RunQuickView3)
        }
    }
    if($comparison(#null,"= Equals","CLIENT PORTAL")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - PROJECT FOLDER SETTINGS OPTION SELECTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            ClientFeedback(#RunClientFeedback)
        }
    }
    if($comparison(#null,"= Equals","[ Post Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Post Module ]", 0, "True")
        }
    }
    if($comparison(#null,"= Equals","[ Succession Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Succession Module ]", 0, "False")
        }
    }
    if($comparison(#null,"= Equals","[ Target Module ]")) {
        then {
            plugin command("Advanced Ubot 2.dll", "tab selected", "[ Target Module ]", 0, "False")
        }
    }
}
ui button("Rest &nbsp;Software&nbsp;") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to close the browser and rest the accounts list?", "ALERT!", "Yes/No/Cancel", "Question", "Default Desktop Only", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes")) {
        then {
            StartLogRunning(#OpenLog)
            ChromeDriverKiller(#ChromeKillerCode)
            Account Rest(#Rest Accounts)
            plugin command("Advanced Ubot.dll", "main button click", "Stop")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            stop script
        }
    }
}
ui stat monitor("Master Countdown",#count_ui_display)
ui button("Start &nbsp;Software") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to start the software?", "ALERT!", "Yes/No/Cancel", "Question", "Default Desktop Only", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE RUNNING - SOFTWARE STARTED - THE START BUTTON HAS BEEN ENGAGED BOTTING OPERATION NOW STARTED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Ubot.dll", "main button click", "Run")
        }
    }
}
ui button("Account - Login") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to login? If you already logged in to the browser this action will close the current browser and launch a new one and login into the next account in the list.", "ALERT!", "Yes Login/Cancel", "Question", "None", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes Login")) {
        then {
            StartLogRunning(#OpenLog)
            ChromeDriverKiller(#ChromeKillerCode)
            Login System(#LoginSystem)
        }
    }
}
ui stat monitor(#diplay_running,"<br>")
ui stat monitor(#main ui,"")
ui button("Stop &nbsp;Software&nbsp;") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to stop the software?", "ALERT!", "Yes Stop/No Cancel", "Question", "None", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes Stop")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE STOPED - THE STOP BUTTON HAS BEEN ENGAGED BOTTING OPERATION NOW STOPPED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            SetOnloadVar(#ResetVarOnload)
            if($comparison(#ScrapeTagsOption,"= Equals","Scrape Related Tags")) {
                then {
                    set(#PrefixHashTags,$PrefixHashTags(#PrefixHashTags),"Global")
                }
            }
            plugin command("Bigtable.dll", "Clear all large list")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            plugin command("Advanced Ubot.dll", "main button click", "Stop")
            stop script
        }
    }
}
ui button("Pause Software") {
    set(#null,$plugin function("Advanced Dialog.dll", "$alert result dialog", "Are you sure you want to pause the software?", "ALERT!", "Yes/No/Cancel", "Question", "Default Desktop Only", "Button 1"),"Global")
    if($comparison(#null,"= Equals","Yes")) {
        then {
            StartLogRunning(#OpenLog)
            DateTimeLogStamp(#RunDateTimeLogStamp)
            run javascript("textarea_id.value += \"{#time} - SOFTWARE PAUSED  - THE PAUSE BUTTON HAS BEEN ENGAGED BOTTING OPERATION NOW PAUSED - LOG RUNNING - INTERNALIZING COMPLETE - {#time}\\n\"
var textarea = document.getElementById(\'textarea_id\');
textarea.scrollTop = textarea.scrollHeight;")
            plugin command("Advanced Systems.dll", "system sound play", "Exclamation")
            if($comparison(#ScrapeTagsOption,"= Equals","Scrape Related Tags")) {
                then {
                    set(#PrefixHashTags,$PrefixHashTags(#PrefixHashTags),"Global")
                }
            }
            plugin command("Advanced Ubot.dll", "main button click", "Pause")
        }
    }
}
